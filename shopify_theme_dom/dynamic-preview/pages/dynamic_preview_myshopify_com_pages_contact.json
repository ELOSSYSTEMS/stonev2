  "mainOuterHtml": "<main id=\"MainContent\" class=\"content-for-layout focus-none\" role=\"main\" tabindex=\"-1\">\n      <div id=\"shopify-section-template--27935320015014__page_hero_banner_UXTzWw\" class=\"shopify-section\"><style data-shopify=\"\">\n  .collection_list_wrapper-template--27935320015014__page_hero_banner_UXTzWw {\n    padding-top: 0px;\n    padding-bottom: 20px;\n    margin: 0 10px;;\n\n  }\n\n\n\n  @media screen and (max-width: 640px) {\n    .collection_list_wrapper-template--27935320015014__page_hero_banner_UXTzWw {\n      padding-top: 0px;\n      padding-bottom: 10px;\n    }\n  }\n</style>\n\n<link href=\"//dynamic-preview.myshopify.com/cdn/shop/t/18/assets/page-hero-banner.css?v=58205107822548130091771645050\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n\n\n  <link href=\"//dynamic-preview.myshopify.com/cdn/shop/t/18/assets/page-breadcrumbs.css?v=10444629455867775861771645050\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n\n<section class=\"page-hero  collection_list_wrapper-template--27935320015014__page_hero_banner_UXTzWw\" style=\"\n    --heading-color: #ffffff;\n    --subheading-color: #ffffff;\n    --breadcrumb-color: #fef9f2;\n    --radius: 12px;\n  \">\n  \n    <div class=\"page-hero__media\">\n      \n        \n        <img src=\"//dynamic-preview.myshopify.com/cdn/shop/files/bg_3_e6f09e65-1f38-4259-af74-1313f4bcabfe.png?v=1769071805&amp;width=2000\" alt=\"Contact\" srcset=\"//dynamic-preview.myshopify.com/cdn/shop/files/bg_3_e6f09e65-1f38-4259-af74-1313f4bcabfe.png?v=1769071805&amp;width=375 375w, //dynamic-preview.myshopify.com/cdn/shop/files/bg_3_e6f09e65-1f38-4259-af74-1313f4bcabfe.png?v=1769071805&amp;width=550 550w, //dynamic-preview.myshopify.com/cdn/shop/files/bg_3_e6f09e65-1f38-4259-af74-1313f4bcabfe.png?v=1769071805&amp;width=750 750w, //dynamic-preview.myshopify.com/cdn/shop/files/bg_3_e6f09e65-1f38-4259-af74-1313f4bcabfe.png?v=1769071805&amp;width=1100 1100w, //dynamic-preview.myshopify.com/cdn/shop/files/bg_3_e6f09e65-1f38-4259-af74-1313f4bcabfe.png?v=1769071805&amp;width=1500 1500w, //dynamic-preview.myshopify.com/cdn/shop/files/bg_3_e6f09e65-1f38-4259-af74-1313f4bcabfe.png?v=1769071805&amp;width=2000 2000w\" width=\"2000\" height=\"422\" loading=\"lazy\" sizes=\"100vw\">\n      \n\n      <div class=\"page-hero__content\">\n        \n          <h1 class=\"page-hero__title\">Get in Touch with Us</h1>\n          <div class=\"page-hero__subtitle\"><p>We’d love to hear from you! Whether you have questions about our products, need skincare advice</p></div>\n        \n\n        \n          <div class=\"page-hero__breadcrumb\">\n            \n<div class=\"breadcrumbs_wrapper\" role=\"navigation\" aria-label=\"breadcrumbs\">\n    <div class=\"container\">\n      <ol class=\"breadcrumbs__list\">\n        <li class=\"breadcrumbs__item\">\n          <a class=\"breadcrumbs__link\" href=\"/\">Home</a>\n        </li>\n        <li class=\"separator\" aria-hidden=\"true\">|</li><li class=\"breadcrumbs__item\">\n              <a class=\"breadcrumbs__link\" href=\"/pages/contact\" aria-current=\"page\">Contact</a>\n            </li></ol>\n    </div>\n  </div>\n          </div>\n        \n      </div>\n    </div>\n\n  \n</section>\n\n\n</div><div id=\"shopify-section-template--27935320015014__contact_info_qa7iJE\" class=\"shopify-section\"><link href=\"//dynamic-preview.myshopify.com/cdn/shop/t/18/assets/contact-with-map.css?v=155464169482040406021771645050\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n\n<section class=\"contact-section\" style=\"\n    --padding-top: 30px;\n    --padding-bottom: 40px;\n    --info-bg: #f4e6d1;\n    --text-color: #331f17;\n    --contact-max-width: var(--page-width);\n  \">\n  <div class=\"contact-wrapper page-width\">\n    <div class=\"contact-grid \"> \n      <!-- INFO BOX -->\n      <div class=\"info-box\">\n        <h2>Customer Support</h2>\n        <p class=\"info-desc\">Our customer support team is here to help you every step of the way. Whether you have questions about our products, your order, or skincare recommendations, we’re just a message away</p>\n\n        \n          <div class=\"contact-item\">\n            \n              <div class=\"icon-wrap\" style=\"--icon-bg: #ffffff;\">\n                <img src=\"//dynamic-preview.myshopify.com/cdn/shop/files/phone-call_1.png?v=1769072281&amp;width=48\" alt=\"Phone\" srcset=\"//dynamic-preview.myshopify.com/cdn/shop/files/phone-call_1.png?v=1769072281&amp;width=48 48w\" width=\"48\" height=\"48\">\n              </div>\n            \n\n            <div class=\"contact-text\">\n              <h4>Phone</h4>\n              <p>(800) 555-0199</p>\n            </div>\n          </div>\n        \n          <div class=\"contact-item\">\n            \n              <div class=\"icon-wrap\" style=\"--icon-bg: #ffffff;\">\n                <img src=\"//dynamic-preview.myshopify.com/cdn/shop/files/email_1.png?v=1769072313&amp;width=48\" alt=\"Email\" srcset=\"//dynamic-preview.myshopify.com/cdn/shop/files/email_1.png?v=1769072313&amp;width=48 48w\" width=\"48\" height=\"48\">\n              </div>\n            \n\n            <div class=\"contact-text\">\n              <h4>Email</h4>\n              <p><a href=\"mailto:xyz@support.com\" title=\"mailto:xyz@support.com\">xyz@support.com</a></p>\n            </div>\n          </div>\n        \n          <div class=\"contact-item\">\n            \n              <div class=\"icon-wrap\" style=\"--icon-bg: #ffffff;\">\n                <img src=\"//dynamic-preview.myshopify.com/cdn/shop/files/location_1.png?v=1769072330&amp;width=48\" alt=\"Address\" srcset=\"//dynamic-preview.myshopify.com/cdn/shop/files/location_1.png?v=1769072330&amp;width=48 48w\" width=\"48\" height=\"48\">\n              </div>\n            \n\n            <div class=\"contact-text\">\n              <h4>Address</h4>\n              <p>Devonshire Rd, Liverpool L8 3TZ, United Kingdom</p>\n            </div>\n          </div>\n        \n      </div>\n\n      <!-- MAP -->\n      \n        <div class=\"map\">\n          <iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d42721.6981424753!2d-3.0140653937512525!3d53.40062126457327!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x487b20f0720a2235%3A0x76309879f36ed56!2sPrinces%20Park!5e0!3m2!1sen!2sin!4v1770459027690!5m2!1sen!2sin\" width=\"600\" height=\"450\" style=\"border:0;\" allowfullscreen=\"\" loading=\"lazy\" referrerpolicy=\"no-referrer-when-downgrade\"></iframe>\n        </div>\n      \n\n    </div>\n  </div>\n</section>\n\n\n</div><section id=\"shopify-section-template--27935320015014__contact_form_UhcCFc\" class=\"shopify-section contact-form\"><link href=\"//dynamic-preview.myshopify.com/cdn/shop/t/18/assets/section-contact-form.css?v=123178624918143250631771645050\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n\n<div id=\"contact-form-section-template--27935320015014__contact_form_UhcCFc\" style=\"\n    background: #fbf6ee;\n    padding-top: 60px;\n    padding-bottom: 60px;\n  \">\n  <div class=\"contact-form-wrapper page-width\">\n    \n      <h2 style=\"color:#331f17\">Send Us A Message</h2>\n    \n\n    \n      <p style=\"color:#331f17\"></p><p>Have a question or special request? Fill out the form below, and our team will get back to you as soon as possible.<br><br></p><p></p>\n    \n<form method=\"post\" action=\"/contact#ContactForm\" id=\"ContactForm\" accept-charset=\"UTF-8\" class=\"main_contact_form\"><input type=\"hidden\" name=\"form_type\" value=\"contact\" style=\"\"><input type=\"hidden\" name=\"utf8\" value=\"✓\" style=\"\">\n\n      <div class=\"contact-form-fields\">\n        <div class=\"contact-form-field\">\n          <label for=\"contact-name\" class=\"visually-hidden\">Full Name</label>\n          <input id=\"contact-name\" class=\"contact-form-input\" type=\"text\" name=\"contact[name]\" placeholder=\"Full Name *\" required=\"\" style=\"\">\n        </div>\n\n        <div class=\"contact-form-field\">\n          <label for=\"contact-email\" class=\"visually-hidden\">Email</label>\n          <input id=\"contact-email\" class=\"contact-form-input\" type=\"email\" name=\"contact[email]\" placeholder=\"Email *\" required=\"\" style=\"\">\n        </div>\n      </div>\n\n      <div class=\"contact-form-fields\">\n        <div class=\"contact-form-field\">\n          <label for=\"contact-phone\" class=\"visually-hidden\">Phone</label>\n          <input id=\"contact-phone\" class=\"contact-form-input\" type=\"tel\" name=\"contact[phone]\" placeholder=\"Phone *\" required=\"\" style=\"\">\n        </div>\n\n        <div class=\"contact-form-field\">\n          <label for=\"contact-subject\" class=\"visually-hidden\">Subject</label>\n          <select id=\"contact-subject\" class=\"contact-form-input\" name=\"contact[subject]\">\n            <option value=\"\">Subject</option>\n            <option>General Inquiry</option>\n            <option>Custom Order</option>\n            <option>Support</option>\n          </select>\n        </div>\n      </div>\n\n      <div class=\"contact-form-field\">\n        <label for=\"contact-message\" class=\"visually-hidden\">Message</label>\n        <textarea id=\"contact-message\" class=\"contact-form-textarea\" name=\"contact[body]\" placeholder=\"Message...\" style=\"\"></textarea>\n      </div>\n\n      <div class=\"contact-form-button-wrap\">\n        <button class=\"button btn-prime\" type=\"submit\">Submit Now</button>\n      </div>\n    </form>\n  </div>\n</div>\n\n\n</section>\n    </main>",
