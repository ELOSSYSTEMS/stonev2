  "mainOuterHtml": "<main id=\"MainContent\" class=\"content-for-layout focus-none\" role=\"main\" tabindex=\"-1\">\n      <section id=\"shopify-section-template--26224395190591__main\" class=\"shopify-section page-section\"><link href=\"//zap-main.myshopify.com/cdn/shop/t/2/assets/section-main-page.css?v=165534704276754180541772782652\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n<style data-shopify=\"\">.section-template--26224395190591__main-padding {\n\n  padding-top: 4rem;\n\n\n\n  padding-bottom: 0;\n\n}\n\n@media screen and (min-width: 750px) { .section-template--26224395190591__main-padding {\n\n  padding-top: 5rem;\n\n\n\n  padding-bottom: 0;\n\n} }\n\n@media screen and (min-width: 1360px) { .section-template--26224395190591__main-padding {\n\n  padding-top: 8rem;\n\n\n\n  padding-bottom: 0;\n\n} }\n\n</style><div class=\"section-template--26224395190591__main-padding container page-width--narrow\">\n  <div class=\"page-header\">\n    <div class=\"page-header__inner\">\n      <h1 class=\"main-page-title page-title title--page h2\">Rich text</h1>\n    </div>\n  </div>\n  <div class=\"rte\">\n    \n  </div>\n</div>\n\n\n</section><section id=\"shopify-section-template--26224395190591__rich_text_BwGFAn\" class=\"shopify-section spaced-section\"><link href=\"//zap-main.myshopify.com/cdn/shop/t/2/assets/section-rich-text.css?v=123149891236179896771772782656\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n<style data-shopify=\"\">.section-template--26224395190591__rich_text_BwGFAn-padding {\n\n  padding-top: 5rem;\n\n\n\n  padding-bottom: 6.4rem;\n\n}\n\n@media screen and (min-width: 750px) { .section-template--26224395190591__rich_text_BwGFAn-padding {\n\n  padding-top: 7.2rem;\n\n\n\n  padding-bottom: 8.8rem;\n\n} }\n\n@media screen and (min-width: 1360px) { .section-template--26224395190591__rich_text_BwGFAn-padding {\n\n  padding-top: 10rem;\n\n\n\n  padding-bottom: 15rem;\n\n} }\n\n  #shopify-section-template--26224395190591__rich_text_BwGFAn {\n\n  padding-top: 0;\n\n\n\n  padding-bottom: 0;\n\n}\n\n@media screen and (min-width: 750px) { #shopify-section-template--26224395190591__rich_text_BwGFAn {\n\n  padding-top: 0;\n\n\n\n  padding-bottom: 0;\n\n} }\n\n@media screen and (min-width: 1360px) { #shopify-section-template--26224395190591__rich_text_BwGFAn {\n\n  padding-top: 0;\n\n\n\n  padding-bottom: 0;\n\n\n} }\n\n</style><div class=\"rich-text rich-text--align-center  rich-text--full-width color-background-1 background\">\n  <div class=\"rich-text__blocks section-template--26224395190591__rich_text_BwGFAn-padding container\"><div class=\"rich-text__subheading body-xl\">\n            OUR MISSION\n          </div><h2 class=\"rich-text__heading title--section h3\">\n            “We’re here to create with intention — not just to make things, but to make them matter.”\n          </h2><div class=\"rich-text__text body-normal rte\">\n            <p>We believe in <em>thoughtful</em> work, <em>honest</em> expression, and the kind of <em>creativity</em> that leaves a mark. <a href=\"/de/pages/our-story\" target=\"_blank\" title=\"Our Story\">Our mission</a> is to build something that feels personal — something that resonates, lasts, and invites others in. We are <strong>independent</strong> by choice, <strong>collaborative</strong> by nature and <strong>driven</strong> by curiosity. </p><p>Whether it’s through words, visuals, or shared experiences, we aim to connect people to ideas that matter.</p><p>This isn’t about noise. It’s about meaning. We’re here to make space for clarity, depth, and the kind of stories that stay with you.</p>\n          </div>\n\n\n\n\n  <a href=\"/de/pages/our-story\" aria-label=\"Learn More\" class=\"button button--primary rich-text__button\">\n    <div class=\"button__content\">\n      <span class=\"button__label\" data-label=\"Learn More\">Learn More</span>\n    </div>\n    \n      <span class=\"animated-button-circle\"></span>\n    \n  </a>\n\n\n</div>\n</div>\n\n\n</section>\n    </main>",
