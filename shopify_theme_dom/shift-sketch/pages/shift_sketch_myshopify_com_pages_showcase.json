  "mainOuterHtml": "<main id=\"MainContent\" class=\"content-for-layout focus-none\" role=\"main\" tabindex=\"-1\">\n      <section id=\"shopify-section-template--28054268641655__page_info\" class=\"shopify-section page-section\"><link href=\"//shift-sketch.myshopify.com/cdn/shop/t/2/assets/section-main-page.css?v=122541859386650611581774270656\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n\n<div class=\"page-section-wrapper container align-left\">\n  <div class=\"page-header\">\n    <div class=\"page-header__inner\">\n      <h1 class=\"page-header__inner-title h5\">Showcase</h1>\n    </div>\n  </div></div>\n\n\n</section><div id=\"shopify-section-template--28054268641655__showcase\" class=\"shopify-section showcase-section\"><link href=\"//shift-sketch.myshopify.com/cdn/shop/t/2/assets/section-showcase.css?v=81040473983087839341774431592\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n<script src=\"//shift-sketch.myshopify.com/cdn/shop/t/2/assets/showcase.js?v=180394286171084760991766398548\" defer=\"defer\"></script>\n<style data-shopify=\"\">\n   #shopify-section-template--28054268641655__showcase {\n\n  padding-top: 0;\n\n\n\n  padding-bottom: 6rem;\n\n}\n\n@media screen and (min-width: 750px) { #shopify-section-template--28054268641655__showcase {\n\n  padding-top: 0;\n\n\n\n  padding-bottom: 8rem;\n\n} }\n\n@media screen and (min-width: 1440px) { #shopify-section-template--28054268641655__showcase {\n\n  padding-top: 0;\n\n\n\n  padding-bottom: 12rem;\n\n\n} }\n\n  .section-template--28054268641655__showcase-padding {\n\n  padding-top: 3.6rem;\n\n\n\n  padding-bottom: 3.6rem;\n\n}\n\n@media screen and (min-width: 750px) { .section-template--28054268641655__showcase-padding {\n\n  padding-top: 5rem;\n\n\n\n  padding-bottom: 5rem;\n\n} }\n\n@media screen and (min-width: 1440px) { .section-template--28054268641655__showcase-padding {\n\n  padding-top: 8rem;\n\n\n\n  padding-bottom: 8rem;\n\n} }\n\n      \n</style>\n\n<div class=\"showcase color-scheme-fa642aef-b473-43e5-a463-cebf3dbd69af background section-template--28054268641655__showcase-padding\">\n  <div id=\"Banner-template--28054268641655__showcase\" class=\"showcase__inner container \">\n    <div class=\"showcase__content has-badge\">\n        <div class=\"showcase__text\">\n          <div class=\"showcase__text_inner\"><div class=\"heading-group__subheading\">Who we are</div>\n              <h3 class=\"showcase__heading h3 richtext-link-inside\">The truth is that creativity has no boundaries, and we turn it into products you love.</h3>\n            </div>\n          \n            <p class=\"showcase__description richtext-link-inside\">Ideas come in unexpected ways, often when you least expect them. While we don’t know what form they’ll take or where they’ll lead, we make sure you have the tools, resources, and support to turn every spark of inspiration into something tangible and meaningful.</p>\n          </div>\n      <div class=\"showcase__img_inner\">\n        <div class=\"showcase__img_inner-wrapper animate reveal--show\" data-scroll-image-reveal=\"\" data-reveal-initialized=\"\">\n          \n            \n            <img src=\"//shift-sketch.myshopify.com/cdn/shop/files/02-promo.jpg?v=1770798966&amp;width=2094\" alt=\"\" srcset=\"//shift-sketch.myshopify.com/cdn/shop/files/02-promo.jpg?v=1770798966&amp;width=360 360w, //shift-sketch.myshopify.com/cdn/shop/files/02-promo.jpg?v=1770798966&amp;width=535 535w, //shift-sketch.myshopify.com/cdn/shop/files/02-promo.jpg?v=1770798966&amp;width=600 600w, //shift-sketch.myshopify.com/cdn/shop/files/02-promo.jpg?v=1770798966&amp;width=720 720w, //shift-sketch.myshopify.com/cdn/shop/files/02-promo.jpg?v=1770798966&amp;width=940 940w, //shift-sketch.myshopify.com/cdn/shop/files/02-promo.jpg?v=1770798966&amp;width=1066 1066w, //shift-sketch.myshopify.com/cdn/shop/files/02-promo.jpg?v=1770798966&amp;width=1200 1200w, //shift-sketch.myshopify.com/cdn/shop/files/02-promo.jpg?v=1770798966&amp;width=1400 1400w, //shift-sketch.myshopify.com/cdn/shop/files/02-promo.jpg?v=1770798966&amp;width=1600 1600w, //shift-sketch.myshopify.com/cdn/shop/files/02-promo.jpg?v=1770798966&amp;width=1800 1800w, //shift-sketch.myshopify.com/cdn/shop/files/02-promo.jpg?v=1770798966&amp;width=2000 2000w\" width=\"2094\" height=\"1439\" sizes=\"(min-width: 750px) 50vw, 100vw\" class=\" scroll-image-reveal__target\" style=\"object-fit: cover\">\n</div>\n        \n          \n            <div class=\"showcase__img_badge\">\n              <img src=\"//shift-sketch.myshopify.com/cdn/shop/files/Group_240.svg?v=1770357248&amp;width=124\" alt=\"\" width=\"124\" height=\"124\" sizes=\"372\" class=\"\" style=\"object-fit: cover\">\n            </div></div>\n    </div>\n  </div>\n</div>\n<div class=\"contact__account contact-modal\" id=\"contact-modal\">\n  <div class=\"contact__content header-modal_content \">\n    <div class=\"contact-form__block \">\n      <div class=\"contact-form__header\">\n        <button type=\"submit\" class=\"button button--tertiary close_modal_element\">\n          <span class=\"button__content\">\n            <span class=\"button__icons-container\">\n              <svg class=\"icon icon-arrow--tertiary-button\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n  <path d=\"M1.0278 8.04455L15.0738 8.04455M15.0738 8.04455L7.95312 15.1653M15.0738 8.04455L7.95312 0.923828\" stroke=\"currentColor\" stroke-linecap=\"square\"></path>\n</svg>\n\n              <svg class=\"icon icon-arrow--tertiary-button\" width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n  <path d=\"M1.0278 8.04455L15.0738 8.04455M15.0738 8.04455L7.95312 15.1653M15.0738 8.04455L7.95312 0.923828\" stroke=\"currentColor\" stroke-linecap=\"square\"></path>\n</svg>\n\n            </span>\n\n            <span class=\"button__label body-small\">Go back</span>\n          </span>\n        </button><h3 class=\"contact-modal_