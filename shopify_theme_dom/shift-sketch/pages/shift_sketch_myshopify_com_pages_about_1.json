  "mainOuterHtml": "<main id=\"MainContent\" class=\"content-for-layout focus-none\" role=\"main\" tabindex=\"-1\">\n      <section id=\"shopify-section-template--27960486953335__page_info\" class=\"shopify-section page-section\"><link href=\"//shift-sketch.myshopify.com/cdn/shop/t/2/assets/section-main-page.css?v=122541859386650611581774270656\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n\n<div class=\"page-section-wrapper container align-left\">\n  <div class=\"page-header\">\n    <div class=\"page-header__inner\">\n      <h1 class=\"page-header__inner-title h5\">About features</h1>\n    </div>\n  </div></div>\n\n\n</section><section id=\"shopify-section-template--27960486953335__about_aGxCH8\" class=\"shopify-section about-section spaced-section\"><link href=\"//shift-sketch.myshopify.com/cdn/shop/t/2/assets/section-about.css?v=62509824689247818701772606722\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n\n<style data-shopify=\"\">\n  #shopify-section-template--27960486953335__about_aGxCH8 {\n\n  padding-top: 0;\n\n\n\n  padding-bottom: 8rem;\n\n}\n\n@media screen and (min-width: 750px) { #shopify-section-template--27960486953335__about_aGxCH8 {\n\n  padding-top: 0;\n\n\n\n  padding-bottom: 12rem;\n\n} }\n\n@media screen and (min-width: 1440px) { #shopify-section-template--27960486953335__about_aGxCH8 {\n\n  padding-top: 0;\n\n\n\n  padding-bottom: 15rem;\n\n\n} }\n\n</style>\n\n<div class=\"about\">\n  <div class=\"container\">\n    <div class=\"about__wraper\">\n      \n      <div class=\"about__img\" style=\"padding-bottom: 48%;\">\n        \n\n          <img src=\"//shift-sketch.myshopify.com/cdn/shop/files/03-about.jpg?v=1770804859&amp;width=1760\" alt=\"\" srcset=\"//shift-sketch.myshopify.com/cdn/shop/files/03-about.jpg?v=1770804859&amp;width=375 375w, //shift-sketch.myshopify.com/cdn/shop/files/03-about.jpg?v=1770804859&amp;width=550 550w, //shift-sketch.myshopify.com/cdn/shop/files/03-about.jpg?v=1770804859&amp;width=750 750w, //shift-sketch.myshopify.com/cdn/shop/files/03-about.jpg?v=1770804859&amp;width=1100 1100w, //shift-sketch.myshopify.com/cdn/shop/files/03-about.jpg?v=1770804859&amp;width=1500 1500w\" width=\"1760\" height=\"2050\" loading=\"lazy\" sizes=\"(min-width: 750px) calc(50vw * 1.13), calc(100vw * 1.13)\" style=\"object-position:41.8879% 12.8781%;object-fit: cover\">\n</div>\n      <div class=\"about_box\">\n        <div class=\"about_item\"><h2 class=\"about__heading h5\">\n              <span class=\"richtext-link-inside\">“Our mission is simple: to craft products that turn inspiration into action and organization into ease.”</span>\n            </h2><div class=\"about__box-author\">\n            \n              <div class=\"about__box-text\">\n                \n                  <div class=\"about__box-name rte large-font\">\n                    <p>The Founders,</p><p>Pavel &amp; Benny</p>\n                  </div>\n                \n              </div>\n            \n          </div>\n        </div>\n        <div class=\"about_item\"><div class=\"about__subtitle\">\n              It all began with a simple idea: to combine timeless design with practical functionality. Starting as a small studio creating handcrafted sketchbooks, planners, and accessories, the focus was always on quality, attention to detail, and thoughtful design. Over the years, these products have found their way into desks, offices, and creative spaces everywhere, helping people organize their days, capture ideas, and turn inspiration into reality.\n            </div></div>\n      </div>\n    </div>\n  </div>\n</div>\n\n</section>\n    </main>",
