  "mainOuterHtml": "<main id=\"MainContent\" class=\"content-for-layout focus-none\" role=\"main\" tabindex=\"-1\">\n      <section id=\"shopify-section-template--28054576628087__hero_PK4M6t\" class=\"shopify-section hero-section\"><link href=\"//shift-sketch.myshopify.com/cdn/shop/t/2/assets/section-hero.css?v=942548224242251471771924679\" rel=\"stylesheet\" type=\"text/css\" media=\"all\">\n<script src=\"//shift-sketch.myshopify.com/cdn/shop/t/2/assets/hero.js?v=28329708647673372831771924678\" defer=\"defer\"></script><style data-shopify=\"\">#shopify-section-template--28054576628087__hero_PK4M6t {\n\n  padding-top: 0;\n\n\n\n  padding-bottom: 6rem;\n\n}\n\n@media screen and (min-width: 750px) { #shopify-section-template--28054576628087__hero_PK4M6t {\n\n  padding-top: 0;\n\n\n\n  padding-bottom: 8rem;\n\n} }\n\n@media screen and (min-width: 1440px) { #shopify-section-template--28054576628087__hero_PK4M6t {\n\n  padding-top: 0;\n\n\n\n  padding-bottom: 12rem;\n\n\n} }\n\n</style>\n\n\n\n<style data-shopify=\"\">.hero-template--28054576628087__hero_PK4M6t .hero__image-primary-wrapper::before {\n     content: '';\n     display: block;\n     width: 0;\n     padding-bottom: 138.4%;\n   }\n   .hero-template--28054576628087__hero_PK4M6t .hero__image-secondary-wrapper::before {\n     content: '';\n     display: block;\n     width: 0;\n     padding-bottom: 138.4%;\n   }\n  \t#shopify-section-template--28054576628087__hero_PK4M6t {\n  \t--ticker-speed : s;\n  }</style><div class=\"hero hero-template--28054576628087__hero_PK4M6t \"><div class=\"wrapper container footer__name\" style=\"width: 100%;\">\n      <svg id=\"authorNameSvg\" preserveAspectRatio=\"xMidYMid meet\" viewBox=\"0 0 204 62\">\n        <text id=\"authorText\" y=\"50%\" dominant-baseline=\"central\" style=\"font-size: 50px;\">Our Story</text>\n      </svg>\n    </div><div class=\"container\">\n    <div class=\"hero__wrapper \">\n      <div class=\"hero__wrapper-text content-top \">\n        <div class=\"hero__text_inner\">\n            <h2 class=\"hero__heading h5 richtext-link-inside\">Every item in our collection is thoughtfully designed to turn everyday moments into inspiring, organized, and beautiful experiences.</h2>\n          </div>\n        \n          <p class=\"hero__description richtext-link-inside\">From sketchbooks and planners to calendars, pads, and accessories, we focus on details that matter and materials that last. Our journey is guided by the belief that stationery should do more than hold your notes—it should spark creativity, support your goals, and make every day feel purposeful.</p>\n        </div>\n      <div class=\"hero__content jarallax\" data-jarallax=\"\">\n        \n\n        <div class=\"hero__left-block\">\n          <div class=\"hero__left-inner \">\n            <div class=\"hero__image-primary-wrapper hero__image-wrapper hero__animation-wrapper animate reveal--show\">\n              \n                \n                \n                \n<img src=\"//shift-sketch.myshopify.com/cdn/shop/files/01-about-01_098b3a6a-3f48-4419-a1c1-f1e58237f787.jpg?v=1770804663&amp;width=2183\" alt=\"\" srcset=\"//shift-sketch.myshopify.com/cdn/shop/files/01-about-01_098b3a6a-3f48-4419-a1c1-f1e58237f787.jpg?v=1770804663&amp;width=360 360w, //shift-sketch.myshopify.com/cdn/shop/files/01-about-01_098b3a6a-3f48-4419-a1c1-f1e58237f787.jpg?v=1770804663&amp;width=535 535w, //shift-sketch.myshopify.com/cdn/shop/files/01-about-01_098b3a6a-3f48-4419-a1c1-f1e58237f787.jpg?v=1770804663&amp;width=600 600w, //shift-sketch.myshopify.com/cdn/shop/files/01-about-01_098b3a6a-3f48-4419-a1c1-f1e58237f787.jpg?v=1770804663&amp;width=720 720w, //shift-sketch.myshopify.com/cdn/shop/files/01-about-01_098b3a6a-3f48-4419-a1c1-f1e58237f787.jpg?v=1770804663&amp;width=940 940w, //shift-sketch.myshopify.com/cdn/shop/files/01-about-01_098b3a6a-3f48-4419-a1c1-f1e58237f787.jpg?v=1770804663&amp;width=1066 1066w, //shift-sketch.myshopify.com/cdn/shop/files/01-about-01_098b3a6a-3f48-4419-a1c1