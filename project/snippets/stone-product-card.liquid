{%- liquid
  assign stone_product = product
  assign stone_surface_style = surface_style | default: 'outline'
  assign stone_show_vendor = show_vendor
  assign stone_show_price = show_price
  assign stone_card_emphasis = card_emphasis | default: 'standard'
  assign stone_show_excerpt = show_excerpt
  assign stone_price_text = stone_product.price | money
  assign stone_excerpt = stone_product.description | strip_html | strip
  assign stone_image_sizes = '(min-width: 64rem) 22rem, (min-width: 48rem) 32vw, 100vw'

  if stone_card_emphasis == 'showcase'
    assign stone_image_sizes = '(min-width: 64rem) 52rem, (min-width: 48rem) 70vw, 100vw'
  elsif stone_card_emphasis == 'comparison'
    assign stone_image_sizes = '(min-width: 64rem) 26rem, (min-width: 48rem) 44vw, 100vw'
  endif

  if show_vendor == nil
    assign stone_show_vendor = true
  endif

  if show_price == nil
    assign stone_show_price = true
  endif

  if show_excerpt == nil
    assign stone_show_excerpt = false
  endif

  if stone_product.price_varies
    assign stone_price_text = stone_product.price_min | money
  endif
-%}
{%- if stone_product != blank -%}
  <article class="stone-product-card stone-product-card--{{ stone_surface_style | escape }} stone-product-card--{{ stone_card_emphasis | escape }}">
    {%- if stone_product.featured_image != blank -%}
      <a class="stone-product-card__media" href="{{ stone_product.url | escape }}">
        {{ stone_product.featured_image | image_url: width: 1200 | image_tag: class: 'stone-product-card__image', loading: 'lazy', widths: '320, 480, 640, 960, 1200', sizes: stone_image_sizes }}
      </a>
    {%- endif -%}

    <div class="stone-product-card__content">
      <h3 class="stone-product-card__title">
        <a class="stone-product-card__title-link" href="{{ stone_product.url | escape }}">{{ stone_product.title | escape }}</a>
      </h3>

      {%- if stone_show_vendor and stone_product.vendor != blank -%}
        <p class="stone-product-card__vendor">{{ stone_product.vendor | escape }}</p>
      {%- endif -%}

      {%- if stone_show_excerpt and stone_excerpt != blank -%}
        <p class="stone-product-card__excerpt">{{ stone_excerpt | truncatewords: 24 | escape }}</p>
      {%- endif -%}

      {%- if stone_show_price -%}
        <p class="stone-product-card__price">
          {%- if stone_product.price_varies -%}
            {{ 'snippets.stone_product_card.from_price' | t: price: stone_price_text }}
          {%- else -%}
            {{ stone_price_text }}
          {%- endif -%}
        </p>
      {%- endif -%}

      <a class="stone-product-card__link" href="{{ stone_product.url | escape }}">{{ 'snippets.stone_product_card.view_product' | t }}</a>
    </div>
  </article>
{%- endif -%}
