{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_intro = section.settings.intro
  assign stone_intro_plain = stone_intro | strip_html | strip
  assign stone_product_handle = section.settings.product
  assign stone_selected_product = all_products[stone_product_handle]
  assign stone_surface_style = section.settings.surface_style | default: 'outline'

  capture stone_section_content
    echo '<div class="stone-product-context-card stone-product-context-card--'
    echo stone_surface_style | escape
    echo '">'

    if stone_intro_plain != blank
      echo '<div class="stone-product-context-card__intro stone-richtext-flow rte">'
      echo stone_intro
      echo '</div>'
    endif

    if stone_product_handle != blank and stone_selected_product != blank
      assign stone_product_description = stone_selected_product.description | strip_html | strip
      echo '<article class="stone-product-context-card__card">'

      if stone_selected_product.featured_image != blank
        echo '<a class="stone-product-context-card__media" href="'
        echo stone_selected_product.url | escape
        echo '">'
        echo stone_selected_product.featured_image | image_url: width: 1200 | image_tag: class: 'stone-product-context-card__image', loading: 'lazy', widths: '480, 720, 960, 1200', sizes: '(min-width: 64rem) 24rem, 100vw'
        echo '</a>'
      endif

      echo '<div class="stone-product-context-card__content">'
      echo '<p class="stone-product-context-card__eyebrow">'
      echo 'sections.stone_product_context_card.product_label' | t
      echo '</p>'
      echo '<h3 class="stone-product-context-card__title">'
      echo stone_selected_product.title | escape
      echo '</h3>'

      if stone_selected_product.vendor != blank
        echo '<p class="stone-product-context-card__meta">'
        echo stone_selected_product.vendor | escape
        echo '</p>'
      endif

      if stone_selected_product.type != blank
        echo '<p class="stone-product-context-card__meta">'
        echo stone_selected_product.type | escape
        echo '</p>'
      endif

      if stone_product_description != blank
        echo '<p class="stone-product-context-card__description">'
        echo stone_product_description | truncatewords: 28 | escape
        echo '</p>'
      endif

      echo '<a class="stone-product-context-card__link" href="'
      echo stone_selected_product.url | escape
      echo '">'
      echo 'sections.stone_product_context_card.view_product' | t
      echo '</a>'
      echo '</div>'
      echo '</article>'
    else
      echo '<p class="stone-product-context-card__empty">'
      echo 'sections.stone_product_context_card.empty_product' | t
      echo '</p>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell', section: section, heading: stone_heading, content: stone_section_content, width: section.settings.width_mode, spacing: section.settings.spacing_mode, shell_class: 'stone-product-context-card-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_product_context_card.name",
  "tag": "section",
  "class": "shopify-section--stone-product-context-card",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_product_context_card.settings.heading.label",
      "info": "t:sections.stone_product_context_card.settings.heading.info"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.stone_product_context_card.settings.intro.label",
      "info": "t:sections.stone_product_context_card.settings.intro.info"
    },
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.stone_product_context_card.settings.product.label",
      "info": "t:sections.stone_product_context_card.settings.product.info"
    },
    {
      "type": "select",
      "id": "surface_style",
      "label": "t:sections.stone_product_context_card.settings.surface_style.label",
      "info": "t:sections.stone_product_context_card.settings.surface_style.info",
      "default": "outline",
      "options": [
        {
          "value": "outline",
          "label": "t:sections.stone_product_context_card.settings.surface_style.options.outline.label"
        },
        {
          "value": "soft",
          "label": "t:sections.stone_product_context_card.settings.surface_style.options.soft.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_product_context_card.settings.width_mode.label",
      "info": "t:sections.stone_product_context_card.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_product_context_card.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_product_context_card.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_product_context_card.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_product_context_card.settings.spacing_mode.label",
      "info": "t:sections.stone_product_context_card.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_product_context_card.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_product_context_card.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_product_context_card.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stone_product_context_card.name"
    }
  ]
}
{% endschema %}
