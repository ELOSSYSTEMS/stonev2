{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_eyebrow = section.settings.eyebrow | strip
  assign stone_body = section.settings.body
  assign stone_body_plain = stone_body | strip_html | strip
  assign stone_primary_cta_label = section.settings.primary_cta_label | strip
  assign stone_primary_cta_link = section.settings.primary_cta_link
  assign stone_secondary_cta_label = section.settings.secondary_cta_label | strip
  assign stone_secondary_cta_link = section.settings.secondary_cta_link
  assign stone_image = section.settings.image
  assign stone_image_alt = section.settings.image_alt | strip
  assign stone_surface_style = section.settings.surface_style | default: 'soft'
  assign stone_media_position = section.settings.media_position | default: 'end'

  capture stone_section_content
    echo '<div class="stone-hero-opening stone-hero-opening--'
    echo stone_surface_style | escape
    echo ' stone-hero-opening--'
    echo stone_media_position | escape
    echo '">'

    echo '<div class="stone-hero-opening__copy">'

    if stone_eyebrow != blank
      echo '<p class="stone-hero-opening__eyebrow">'
      echo stone_eyebrow | escape
      echo '</p>'
    endif

    if stone_body_plain != blank
      echo '<div class="stone-hero-opening__body stone-richtext-flow rte">'
      echo stone_body
      echo '</div>'
    else
      echo '<p class="stone-hero-opening__empty">'
      echo 'sections.stone_hero_opening.empty' | t
      echo '</p>'
    endif

    if stone_primary_cta_label != blank or stone_secondary_cta_label != blank
      echo '<div class="stone-hero-opening__actions">'

      if stone_primary_cta_label != blank and stone_primary_cta_link != blank
        echo '<a class="stone-utility-action-group__link stone-utility-action-group__link--primary" href="'
        echo stone_primary_cta_link
        echo '">'
        echo stone_primary_cta_label | escape
        echo '</a>'
      endif

      if stone_secondary_cta_label != blank and stone_secondary_cta_link != blank
        echo '<a class="stone-utility-action-group__link" href="'
        echo stone_secondary_cta_link
        echo '">'
        echo stone_secondary_cta_label | escape
        echo '</a>'
      endif

      echo '</div>'
    endif

    echo '</div>'

    echo '<div class="stone-hero-opening__media">'
    if stone_image != blank
      echo stone_image | image_url: width: 1800 | image_tag: class: 'stone-hero-opening__image', loading: 'eager', widths: '720, 960, 1200, 1600, 1800', sizes: '(min-width: 64rem) 34rem, 100vw', alt: stone_image_alt
    else
      echo '<div class="stone-hero-opening__placeholder" aria-hidden="true">'
      echo 'lifestyle-1' | placeholder_svg_tag: 'stone-hero-opening__placeholder-svg'
      echo '</div>'
    endif
    echo '</div>'

    echo '</div>'
  endcapture

  render 'stone-section-shell',
    section: section,
    heading: stone_heading,
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-hero-opening-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_hero_opening.name",
  "tag": "section",
  "class": "shopify-section--stone-hero-opening",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_hero_opening.settings.heading.label",
      "info": "t:sections.stone_hero_opening.settings.heading.info"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.stone_hero_opening.settings.eyebrow.label",
      "info": "t:sections.stone_hero_opening.settings.eyebrow.info"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "t:sections.stone_hero_opening.settings.body.label",
      "info": "t:sections.stone_hero_opening.settings.body.info"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "t:sections.stone_hero_opening.settings.primary_cta_label.label",
      "info": "t:sections.stone_hero_opening.settings.primary_cta_label.info"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "t:sections.stone_hero_opening.settings.primary_cta_link.label",
      "info": "t:sections.stone_hero_opening.settings.primary_cta_link.info"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "t:sections.stone_hero_opening.settings.secondary_cta_label.label",
      "info": "t:sections.stone_hero_opening.settings.secondary_cta_label.info"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "t:sections.stone_hero_opening.settings.secondary_cta_link.label",
      "info": "t:sections.stone_hero_opening.settings.secondary_cta_link.info"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.stone_hero_opening.settings.image.label",
      "info": "t:sections.stone_hero_opening.settings.image.info"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "t:sections.stone_hero_opening.settings.image_alt.label",
      "info": "t:sections.stone_hero_opening.settings.image_alt.info"
    },
    {
      "type": "select",
      "id": "surface_style",
      "label": "t:sections.stone_hero_opening.settings.surface_style.label",
      "info": "t:sections.stone_hero_opening.settings.surface_style.info",
      "default": "soft",
      "options": [
        {
          "value": "outline",
          "label": "t:sections.stone_hero_opening.settings.surface_style.options.outline.label"
        },
        {
          "value": "soft",
          "label": "t:sections.stone_hero_opening.settings.surface_style.options.soft.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "t:sections.stone_hero_opening.settings.media_position.label",
      "info": "t:sections.stone_hero_opening.settings.media_position.info",
      "default": "end",
      "options": [
        {
          "value": "start",
          "label": "t:sections.stone_hero_opening.settings.media_position.options.start.label"
        },
        {
          "value": "end",
          "label": "t:sections.stone_hero_opening.settings.media_position.options.end.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_hero_opening.settings.width_mode.label",
      "info": "t:sections.stone_hero_opening.settings.width_mode.info",
      "default": "wide",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_hero_opening.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_hero_opening.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_hero_opening.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_hero_opening.settings.spacing_mode.label",
      "info": "t:sections.stone_hero_opening.settings.spacing_mode.info",
      "default": "relaxed",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_hero_opening.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_hero_opening.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_hero_opening.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stone_hero_opening.name"
    }
  ]
}
{% endschema %}
