{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_intro = section.settings.intro
  assign stone_intro_plain = stone_intro | strip_html | strip
  assign stone_selected_collection = section.settings.collection
  assign stone_product_limit = section.settings.product_limit | default: 4
  assign stone_surface_style = section.settings.surface_style | default: 'outline'

  capture stone_section_content
    echo '<div class="stone-featured-collection-grid stone-featured-collection-grid--'
    echo stone_surface_style | escape
    echo '">' 

    if stone_intro_plain != blank
      echo '<div class="stone-featured-collection-grid__intro stone-richtext-flow rte">'
      echo stone_intro
      echo '</div>'
    endif

    if stone_selected_collection != blank and stone_selected_collection.all_products_count > 0
      assign stone_collection_description = stone_selected_collection.description | strip_html | strip

      echo '<div class="stone-featured-collection-grid__summary">'
      echo '<div class="stone-featured-collection-grid__summary-copy">'
      echo '<p class="stone-featured-collection-grid__eyebrow">'
      echo 'sections.stone_featured_collection_grid.collection_label' | t
      echo '</p>'
      echo '<h3 class="stone-featured-collection-grid__title">'
      echo stone_selected_collection.title | escape
      echo '</h3>'
      echo '<p class="stone-featured-collection-grid__meta">'
      echo 'sections.stone_featured_collection_grid.product_count' | t: count: stone_selected_collection.all_products_count
      echo '</p>'

      if stone_collection_description != blank
        echo '<p class="stone-featured-collection-grid__description">'
        echo stone_collection_description | truncatewords: 24 | escape
        echo '</p>'
      endif
      echo '</div>'

      echo '<a class="stone-featured-collection-grid__collection-link" href="'
      echo stone_selected_collection.url | escape
      echo '">'
      echo 'sections.stone_featured_collection_grid.view_collection' | t
      echo '</a>'
      echo '</div>'

      echo '<div class="stone-featured-collection-grid__products">'
      for product in stone_selected_collection.products limit: stone_product_limit
        render 'stone-product-card',
          product: product,
          show_vendor: section.settings.show_vendor,
          show_price: section.settings.show_price,
          surface_style: 'outline'
      endfor
      echo '</div>'
    else
      echo '<p class="stone-featured-collection-grid__empty">'
      echo 'sections.stone_featured_collection_grid.empty_collection' | t
      echo '</p>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell',
    section: section,
    heading: stone_heading,
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-featured-collection-grid-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_featured_collection_grid.name",
  "tag": "section",
  "class": "shopify-section--stone-featured-collection-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_featured_collection_grid.settings.heading.label",
      "info": "t:sections.stone_featured_collection_grid.settings.heading.info"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.stone_featured_collection_grid.settings.intro.label",
      "info": "t:sections.stone_featured_collection_grid.settings.intro.info"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.stone_featured_collection_grid.settings.collection.label",
      "info": "t:sections.stone_featured_collection_grid.settings.collection.info"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "t:sections.stone_featured_collection_grid.settings.product_limit.label",
      "info": "t:sections.stone_featured_collection_grid.settings.product_limit.info",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.stone_featured_collection_grid.settings.show_vendor.label",
      "info": "t:sections.stone_featured_collection_grid.settings.show_vendor.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "t:sections.stone_featured_collection_grid.settings.show_price.label",
      "info": "t:sections.stone_featured_collection_grid.settings.show_price.info",
      "default": true
    },
    {
      "type": "select",
      "id": "surface_style",
      "label": "t:sections.stone_featured_collection_grid.settings.surface_style.label",
      "info": "t:sections.stone_featured_collection_grid.settings.surface_style.info",
      "default": "outline",
      "options": [
        {
          "value": "outline",
          "label": "t:sections.stone_featured_collection_grid.settings.surface_style.options.outline.label"
        },
        {
          "value": "soft",
          "label": "t:sections.stone_featured_collection_grid.settings.surface_style.options.soft.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_featured_collection_grid.settings.width_mode.label",
      "info": "t:sections.stone_featured_collection_grid.settings.width_mode.info",
      "default": "wide",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_featured_collection_grid.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_featured_collection_grid.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_featured_collection_grid.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_featured_collection_grid.settings.spacing_mode.label",
      "info": "t:sections.stone_featured_collection_grid.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_featured_collection_grid.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_featured_collection_grid.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_featured_collection_grid.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stone_featured_collection_grid.name"
    }
  ]
}
{% endschema %}
