{%- liquid
  assign stone_brand_name = settings.stone_brand_name | strip
  assign stone_primary_menu = section.settings.menu
  assign stone_show_search = section.settings.show_search
  assign stone_show_cart_link = section.settings.show_cart_link
  assign stone_show_locale_switcher = section.settings.show_locale_switcher
  assign stone_mobile_drawer_id = 'StoneMobileNavigationDrawer-' | append: section.id
  assign stone_search_drawer_id = 'StoneSearchDrawer-' | append: section.id

  if stone_brand_name == blank
    assign stone_brand_name = shop.name
  endif
-%}
<header class="stone-global-header" role="banner">
  <div class="stone-global-header__inner">
    <button
      class="stone-global-header__drawer-trigger"
      type="button"
      aria-controls="{{ stone_mobile_drawer_id }}"
      aria-expanded="false"
      data-stone-drawer-trigger
      data-stone-mobile-drawer-trigger
    >
      <span class="stone-global-header__drawer-icon" aria-hidden="true"></span>
      <span>Menu</span>
    </button>

    <a class="stone-global-header__brand" href="{{ routes.root_url }}">
      {{ stone_brand_name | escape }}
    </a>

    <nav class="stone-global-header__nav" aria-label="{{ 'snippets.stone_global_header.primary_navigation' | t }}">
      {%- if stone_primary_menu != blank and stone_primary_menu.links.size > 0 -%}
        <ul class="stone-global-header__menu" role="list">
          {%- for link in stone_primary_menu.links -%}
            <li class="stone-global-header__menu-item">
              <a class="stone-global-header__menu-link" href="{{ link.url }}">{{ link.title | escape }}</a>
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <a class="stone-global-header__menu-link" href="{{ routes.root_url }}">
          {{ 'snippets.stone_global_header.home' | t }}
        </a>
      {%- endif -%}
    </nav>

    <div class="stone-global-header__utility">
      {%- if stone_show_search -%}
        <button
          class="stone-global-header__utility-link stone-global-header__search-trigger"
          type="button"
          aria-controls="{{ stone_search_drawer_id }}"
          aria-expanded="false"
          data-stone-drawer-trigger
          data-stone-search-drawer-trigger
        >
          {{ 'snippets.stone_global_header.search_label' | t }}
        </button>

        <form class="stone-global-header__search" action="{{ routes.search_url }}" method="get" role="search">
          <label class="stone-visually-hidden" for="StoneHeaderSearch-{{ section.id }}">
            {{ 'snippets.stone_global_header.search_label' | t }}
          </label>
          <input
            id="StoneHeaderSearch-{{ section.id }}"
            class="stone-global-header__search-input"
            type="search"
            name="q"
            value="{{ search.terms | escape }}"
            placeholder="{{ 'snippets.stone_global_header.search_placeholder' | t }}"
          >
          <button class="stone-global-header__search-submit" type="submit">
            {{ 'snippets.stone_global_header.search_submit' | t }}
          </button>
        </form>
      {%- endif -%}

      {%- if stone_show_cart_link -%}
        <a class="stone-global-header__utility-link" href="{{ routes.cart_url }}">
          {{ 'snippets.stone_global_header.cart' | t }}
        </a>
      {%- endif -%}

      {%- if stone_show_locale_switcher and localization.available_languages.size > 1 -%}
        {%- form 'localization', class: 'stone-global-header__locale-form' -%}
          <label class="stone-visually-hidden" for="StoneHeaderLocale-{{ section.id }}">
            {{ 'snippets.stone_global_header.locale_label' | t }}
          </label>
          <select id="StoneHeaderLocale-{{ section.id }}" class="stone-global-header__locale-select" name="locale_code">
            {%- for language in localization.available_languages -%}
              <option
                value="{{ language.iso_code }}"
                {%- if language.iso_code == localization.language.iso_code %} selected{% endif -%}
              >
                {{ language.endonym_name | capitalize | escape }}
              </option>
            {%- endfor -%}
          </select>
          <button class="stone-global-header__locale-submit" type="submit">
            {{ 'snippets.stone_global_header.locale_submit' | t }}
          </button>
        {%- endform -%}
      {%- endif -%}
    </div>
  </div>
</header>

<div
  id="{{ stone_mobile_drawer_id }}"
  class="stone-mobile-navigation-drawer"
  data-stone-drawer
  data-stone-drawer-state="closed"
  data-stone-mobile-drawer
  data-stone-mobile-drawer-state="closed"
  hidden
>
  <button
    class="stone-mobile-navigation-drawer__overlay"
    type="button"
    aria-label="Close menu"
    data-stone-drawer-close
    data-stone-mobile-drawer-close
  ></button>

  <aside
    class="stone-mobile-navigation-drawer__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="{{ stone_mobile_drawer_id }}-Title"
    tabindex="-1"
    data-stone-drawer-panel
    data-stone-mobile-drawer-panel
  >
    <div class="stone-mobile-navigation-drawer__header">
      <h2 id="{{ stone_mobile_drawer_id }}-Title" class="stone-mobile-navigation-drawer__title">
        Menu
      </h2>
      <button
        class="stone-mobile-navigation-drawer__close"
        type="button"
        data-stone-drawer-close
        data-stone-mobile-drawer-close
      >
        Close
      </button>
    </div>

    <nav class="stone-mobile-navigation-drawer__nav" aria-label="{{ 'snippets.stone_global_header.primary_navigation' | t }}">
      {%- if stone_primary_menu != blank and stone_primary_menu.links.size > 0 -%}
        <ul class="stone-mobile-navigation-drawer__menu" role="list">
          {%- for link in stone_primary_menu.links -%}
            <li class="stone-mobile-navigation-drawer__menu-item">
              <a class="stone-mobile-navigation-drawer__menu-link" href="{{ link.url }}">{{ link.title | escape }}</a>
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <a class="stone-mobile-navigation-drawer__menu-link" href="{{ routes.root_url }}">
          {{ 'snippets.stone_global_header.home' | t }}
        </a>
      {%- endif -%}
    </nav>
  </aside>
</div>

{%- if stone_show_search -%}
  <div
    id="{{ stone_search_drawer_id }}"
    class="stone-search-drawer"
    data-stone-drawer
    data-stone-search-drawer
    data-stone-drawer-state="closed"
    hidden
  >
    <button
      class="stone-search-drawer__overlay"
      type="button"
      aria-label="Close search"
      data-stone-drawer-close
      data-stone-search-drawer-close
    ></button>

    <aside
      class="stone-search-drawer__panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="{{ stone_search_drawer_id }}-Title"
      tabindex="-1"
      data-stone-drawer-panel
      data-stone-search-drawer-panel
    >
      <div class="stone-search-drawer__header">
        <h2 id="{{ stone_search_drawer_id }}-Title" class="stone-search-drawer__title">
          {{ 'snippets.stone_global_header.search_label' | t }}
        </h2>
        <button
          class="stone-search-drawer__close"
          type="button"
          data-stone-drawer-close
          data-stone-search-drawer-close
        >
          Close
        </button>
      </div>

      <form class="stone-search-drawer__form" action="{{ routes.search_url }}" method="get" role="search">
        <label class="stone-search-drawer__label" for="StoneSearchDrawerQuery-{{ section.id }}">
          {{ 'snippets.stone_global_header.search_label' | t }}
        </label>
        <div class="stone-search-drawer__form-row">
          <input
            id="StoneSearchDrawerQuery-{{ section.id }}"
            class="stone-search-drawer__input"
            type="search"
            name="q"
            value="{{ search.terms | escape }}"
            placeholder="{{ 'snippets.stone_global_header.search_placeholder' | t }}"
          >
          <button class="stone-search-drawer__submit" type="submit">
            {{ 'snippets.stone_global_header.search_submit' | t }}
          </button>
        </div>
      </form>
    </aside>
  </div>
{%- endif -%}

<script src="{{ 'stone-drawer.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.stone_header_main.name",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:sections.stone_header_main.settings.menu.label",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "t:sections.stone_header_main.settings.show_search.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart_link",
      "label": "t:sections.stone_header_main.settings.show_cart_link.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_locale_switcher",
      "label": "t:sections.stone_header_main.settings.show_locale_switcher.label",
      "default": true
    }
  ]
}
{% endschema %}
