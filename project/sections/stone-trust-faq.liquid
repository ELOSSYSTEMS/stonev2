{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_intro = section.settings.intro
  assign stone_intro_plain = stone_intro | strip_html | strip
  assign stone_surface_style = section.settings.surface_style | default: 'outline'

  capture stone_section_content
    echo '<div class="stone-trust-faq stone-trust-faq--'
    echo stone_surface_style | escape
    echo '">'

    if stone_intro_plain != blank
      echo '<div class="stone-trust-faq__intro stone-richtext-flow rte">'
      echo stone_intro
      echo '</div>'
    endif

    if section.blocks.size > 0
      echo '<div class="stone-trust-faq__items">'
      for block in section.blocks
        assign stone_question = block.settings.question | strip
        assign stone_answer = block.settings.answer
        assign stone_answer_plain = stone_answer | strip_html | strip

        if stone_question != blank or stone_answer_plain != blank
          echo '<details class="stone-trust-faq__item"'
          echo block.shopify_attributes
          echo '>'
          echo '<summary class="stone-trust-faq__summary">'
          if stone_question != blank
            echo stone_question | escape
          else
            echo 'sections.stone_trust_faq.blocks.item.fallback_question' | t
          endif
          echo '</summary>'
          echo '<div class="stone-trust-faq__answer stone-richtext-flow rte">'
          if stone_answer_plain != blank
            echo stone_answer
          else
            echo '<p>'
            echo 'sections.stone_trust_faq.blocks.item.empty_answer' | t
            echo '</p>'
          endif
          echo '</div>'
          echo '</details>'
        endif
      endfor
      echo '</div>'
    else
      echo '<p class="stone-trust-faq__empty">'
      echo 'sections.stone_trust_faq.empty' | t
      echo '</p>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell', section: section, heading: stone_heading, content: stone_section_content, width: section.settings.width_mode, spacing: section.settings.spacing_mode, shell_class: 'stone-trust-faq-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_trust_faq.name",
  "tag": "section",
  "class": "shopify-section--stone-trust-faq",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_trust_faq.settings.heading.label",
      "info": "t:sections.stone_trust_faq.settings.heading.info"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.stone_trust_faq.settings.intro.label",
      "info": "t:sections.stone_trust_faq.settings.intro.info"
    },
    {
      "type": "select",
      "id": "surface_style",
      "label": "t:sections.stone_trust_faq.settings.surface_style.label",
      "info": "t:sections.stone_trust_faq.settings.surface_style.info",
      "default": "outline",
      "options": [
        {
          "value": "outline",
          "label": "t:sections.stone_trust_faq.settings.surface_style.options.outline.label"
        },
        {
          "value": "soft",
          "label": "t:sections.stone_trust_faq.settings.surface_style.options.soft.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_trust_faq.settings.width_mode.label",
      "info": "t:sections.stone_trust_faq.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_trust_faq.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_trust_faq.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_trust_faq.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_trust_faq.settings.spacing_mode.label",
      "info": "t:sections.stone_trust_faq.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_trust_faq.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_trust_faq.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_trust_faq.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "t:sections.stone_trust_faq.blocks.item.name",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "t:sections.stone_trust_faq.blocks.item.settings.question.label",
          "info": "t:sections.stone_trust_faq.blocks.item.settings.question.info"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "t:sections.stone_trust_faq.blocks.item.settings.answer.label",
          "info": "t:sections.stone_trust_faq.blocks.item.settings.answer.info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stone_trust_faq.name",
      "blocks": [
        {
          "type": "item"
        },
        {
          "type": "item"
        }
      ]
    }
  ]
}
{% endschema %}
