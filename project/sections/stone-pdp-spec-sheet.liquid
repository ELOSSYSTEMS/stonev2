{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_intro = section.settings.intro
  assign stone_intro_plain = stone_intro | strip_html | strip
  assign stone_note = section.settings.note
  assign stone_note_plain = stone_note | strip_html | strip
  assign stone_rendered_rows = 0

  capture stone_spec_rows
    for block in section.blocks
      assign stone_group = block.settings.group_label | strip
      assign stone_label = block.settings.spec_label | strip
      assign stone_value = block.settings.spec_value | strip
      assign stone_row_note = block.settings.note | strip

      if stone_group != blank or stone_label != blank or stone_value != blank or stone_row_note != blank
        assign stone_rendered_rows = stone_rendered_rows | plus: 1
        echo '<div class="stone-pdp-spec-sheet__item" '
        echo block.shopify_attributes
        echo '>'
        if stone_group != blank
          echo '<p class="stone-pdp-spec-sheet__group">'
          echo stone_group | escape
          echo '</p>'
        endif
        echo '<dt class="stone-pdp-spec-sheet__term">'
        if stone_label != blank
          echo stone_label | escape
        else
          echo 'sections.stone_pdp_spec_sheet.blocks.row.fallback_label' | t
        endif
        echo '</dt>'
        echo '<dd class="stone-pdp-spec-sheet__value">'
        if stone_value != blank
          echo stone_value | escape
        else
          echo 'sections.stone_pdp_spec_sheet.blocks.row.empty_value' | t
        endif
        if stone_row_note != blank
          echo '<span class="stone-pdp-spec-sheet__note">'
          echo stone_row_note | escape
          echo '</span>'
        endif
        echo '</dd>'
        echo '</div>'
      endif
    endfor
  endcapture

  capture stone_section_content
    echo '<div class="stone-pdp-spec-sheet">'

    if stone_intro_plain != blank
      echo '<div class="stone-pdp-spec-sheet__intro stone-richtext-flow rte">'
      echo stone_intro
      echo '</div>'
    endif

    if stone_rendered_rows > 0
      echo '<dl class="stone-pdp-spec-sheet__list">'
      echo stone_spec_rows
      echo '</dl>'
    else
      echo '<p class="stone-pdp-spec-sheet__empty">'
      echo 'sections.stone_pdp_spec_sheet.empty' | t
      echo '</p>'
    endif

    if stone_note_plain != blank
      echo '<div class="stone-pdp-spec-sheet__footer-note stone-richtext-flow rte">'
      echo stone_note
      echo '</div>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell',
    section: section,
    heading: stone_heading,
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-pdp-spec-sheet-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_pdp_spec_sheet.name",
  "tag": "section",
  "class": "shopify-section--stone-pdp-spec-sheet",
  "max_blocks": 16,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_pdp_spec_sheet.settings.heading.label",
      "info": "t:sections.stone_pdp_spec_sheet.settings.heading.info",
      "default": "Specifications"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.stone_pdp_spec_sheet.settings.intro.label",
      "info": "t:sections.stone_pdp_spec_sheet.settings.intro.info"
    },
    {
      "type": "richtext",
      "id": "note",
      "label": "t:sections.stone_pdp_spec_sheet.settings.note.label",
      "info": "t:sections.stone_pdp_spec_sheet.settings.note.info"
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_pdp_spec_sheet.settings.width_mode.label",
      "info": "t:sections.stone_pdp_spec_sheet.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_pdp_spec_sheet.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_pdp_spec_sheet.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_pdp_spec_sheet.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_pdp_spec_sheet.settings.spacing_mode.label",
      "info": "t:sections.stone_pdp_spec_sheet.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_pdp_spec_sheet.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_pdp_spec_sheet.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_pdp_spec_sheet.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "t:sections.stone_pdp_spec_sheet.blocks.row.name",
      "settings": [
        {
          "type": "text",
          "id": "group_label",
          "label": "t:sections.stone_pdp_spec_sheet.blocks.row.settings.group_label.label",
          "info": "t:sections.stone_pdp_spec_sheet.blocks.row.settings.group_label.info"
        },
        {
          "type": "text",
          "id": "spec_label",
          "label": "t:sections.stone_pdp_spec_sheet.blocks.row.settings.spec_label.label",
          "info": "t:sections.stone_pdp_spec_sheet.blocks.row.settings.spec_label.info"
        },
        {
          "type": "text",
          "id": "spec_value",
          "label": "t:sections.stone_pdp_spec_sheet.blocks.row.settings.spec_value.label",
          "info": "t:sections.stone_pdp_spec_sheet.blocks.row.settings.spec_value.info"
        },
        {
          "type": "text",
          "id": "note",
          "label": "t:sections.stone_pdp_spec_sheet.blocks.row.settings.note.label",
          "info": "t:sections.stone_pdp_spec_sheet.blocks.row.settings.note.info"
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  },
  "presets": [
    {
      "name": "t:sections.stone_pdp_spec_sheet.name",
      "blocks": [
        {
          "type": "row"
        },
        {
          "type": "row"
        },
        {
          "type": "row"
        }
      ]
    }
  ]
}
{% endschema %}
