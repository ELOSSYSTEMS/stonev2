{%- liquid
  assign stone_cart_drawer_id = 'StoneCartDrawer-Section-' | append: section.id
-%}

<div
  id="{{ stone_cart_drawer_id }}"
  class="stone-cart-drawer stone-cart-drawer--section"
  data-stone-drawer
  data-stone-cart-drawer
  data-stone-drawer-state="closed"
  hidden
>
  <button
    class="stone-cart-drawer__overlay"
    type="button"
    aria-label="Close cart"
    data-stone-drawer-close
    data-stone-cart-drawer-close
  ></button>

  <aside
    class="stone-cart-drawer__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="{{ stone_cart_drawer_id }}-Title"
    tabindex="-1"
    data-stone-drawer-panel
    data-stone-cart-drawer-panel
  >
    <div class="stone-cart-drawer__header">
      <h2 id="{{ stone_cart_drawer_id }}-Title" class="stone-cart-drawer__title">
        {{ 'snippets.stone_global_header.cart' | t }}
      </h2>
      <button
        class="stone-cart-drawer__close"
        type="button"
        data-stone-drawer-close
        data-stone-cart-drawer-close
      >
        Close
      </button>
    </div>

    <div class="stone-cart-drawer__body">
      {%- if cart.item_count > 0 -%}
        <p class="stone-cart-drawer__summary">
          {{ cart.item_count }} items
        </p>

        <ul class="stone-cart-drawer__items" role="list">
          {%- for line_item in cart.items -%}
            <li class="stone-cart-drawer__item">
              {%- if line_item.image != blank -%}
                <a class="stone-cart-drawer__media" href="{{ line_item.url }}">
                  {{
                    line_item.image
                    | image_url: width: 120
                    | image_tag:
                      loading: 'lazy',
                      widths: '80, 120',
                      sizes: '4rem',
                      class: 'stone-cart-drawer__image',
                      alt: line_item.image.alt
                    }}
                </a>
              {%- endif -%}

              <div class="stone-cart-drawer__item-content">
                <a class="stone-cart-drawer__item-title" href="{{ line_item.url }}">
                  {{ line_item.product.title | escape }}
                </a>
                {%- unless line_item.product.has_only_default_variant -%}
                  <p class="stone-cart-drawer__variant">
                    {{ line_item.variant.title | escape }}
                  </p>
                {%- endunless -%}
                <p class="stone-cart-drawer__meta">
                  {{ line_item.quantity }} x {{ line_item.final_price | money }}
                </p>
                <p class="stone-cart-drawer__price">
                  {{ line_item.final_line_price | money }}
                </p>
              </div>
            </li>
          {%- endfor -%}
        </ul>

        <p class="stone-cart-drawer__total">
          Total {{ cart.total_price | money }}
        </p>
      {%- else -%}
        <p class="stone-cart-drawer__empty">
          Your cart is empty.
        </p>
      {%- endif -%}

      <a class="stone-cart-drawer__view-cart" href="{{ routes.cart_url }}">
        View cart
      </a>
    </div>
  </aside>
</div>

<script src="{{ 'stone-drawer.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.stone_cart_drawer.name",
  "settings": []
}
{% endschema %}
