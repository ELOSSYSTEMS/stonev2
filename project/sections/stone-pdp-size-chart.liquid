{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_intro = section.settings.intro
  assign stone_intro_plain = stone_intro | strip_html | strip
  assign stone_note = section.settings.note
  assign stone_note_plain = stone_note | strip_html | strip
  assign stone_rendered_rows = 0

  capture stone_size_rows
    for block in section.blocks
      assign stone_size_label = block.settings.size_label | strip
      assign stone_measurement = block.settings.measurement | strip
      assign stone_row_note = block.settings.note | strip

      if stone_size_label != blank or stone_measurement != blank or stone_row_note != blank
        assign stone_rendered_rows = stone_rendered_rows | plus: 1
        echo '<tr class="stone-pdp-size-chart__row" '
        echo block.shopify_attributes
        echo '>'
        echo '<th class="stone-pdp-size-chart__cell stone-pdp-size-chart__cell--heading" scope="row">'
        if stone_size_label != blank
          echo stone_size_label | escape
        else
          echo 'sections.stone_pdp_size_chart.blocks.row.fallback_size' | t
        endif
        echo '</th>'
        echo '<td class="stone-pdp-size-chart__cell">'
        if stone_measurement != blank
          echo stone_measurement | escape
        else
          echo 'sections.stone_pdp_size_chart.blocks.row.empty_measurement' | t
        endif
        echo '</td>'
        echo '<td class="stone-pdp-size-chart__cell">'
        if stone_row_note != blank
          echo stone_row_note | escape
        endif
        echo '</td>'
        echo '</tr>'
      endif
    endfor
  endcapture

  capture stone_section_content
    echo '<div class="stone-pdp-size-chart">'

    if stone_intro_plain != blank
      echo '<div class="stone-pdp-size-chart__intro stone-richtext-flow rte">'
      echo stone_intro
      echo '</div>'
    endif

    if stone_rendered_rows > 0
      echo '<div class="stone-pdp-size-chart__table-wrap">'
      echo '<table class="stone-pdp-size-chart__table">'
      echo '<thead><tr>'
      echo '<th scope="col">'
      echo 'sections.stone_pdp_size_chart.headers.size' | t
      echo '</th>'
      echo '<th scope="col">'
      echo 'sections.stone_pdp_size_chart.headers.measurement' | t
      echo '</th>'
      echo '<th scope="col">'
      echo 'sections.stone_pdp_size_chart.headers.note' | t
      echo '</th>'
      echo '</tr></thead>'
      echo '<tbody>'
      echo stone_size_rows
      echo '</tbody>'
      echo '</table>'
      echo '</div>'
    else
      echo '<p class="stone-pdp-size-chart__empty">'
      echo 'sections.stone_pdp_size_chart.empty' | t
      echo '</p>'
    endif

    if stone_note_plain != blank
      echo '<div class="stone-pdp-size-chart__note stone-richtext-flow rte">'
      echo stone_note
      echo '</div>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell', section: section, heading: stone_heading, content: stone_section_content, width: section.settings.width_mode, spacing: section.settings.spacing_mode, shell_class: 'stone-pdp-size-chart-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_pdp_size_chart.name",
  "tag": "section",
  "class": "shopify-section--stone-pdp-size-chart",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_pdp_size_chart.settings.heading.label",
      "info": "t:sections.stone_pdp_size_chart.settings.heading.info",
      "default": "Size chart"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.stone_pdp_size_chart.settings.intro.label",
      "info": "t:sections.stone_pdp_size_chart.settings.intro.info"
    },
    {
      "type": "richtext",
      "id": "note",
      "label": "t:sections.stone_pdp_size_chart.settings.note.label",
      "info": "t:sections.stone_pdp_size_chart.settings.note.info"
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_pdp_size_chart.settings.width_mode.label",
      "info": "t:sections.stone_pdp_size_chart.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_pdp_size_chart.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_pdp_size_chart.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_pdp_size_chart.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_pdp_size_chart.settings.spacing_mode.label",
      "info": "t:sections.stone_pdp_size_chart.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_pdp_size_chart.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_pdp_size_chart.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_pdp_size_chart.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "t:sections.stone_pdp_size_chart.blocks.row.name",
      "settings": [
        {
          "type": "text",
          "id": "size_label",
          "label": "t:sections.stone_pdp_size_chart.blocks.row.settings.size_label.label",
          "info": "t:sections.stone_pdp_size_chart.blocks.row.settings.size_label.info"
        },
        {
          "type": "text",
          "id": "measurement",
          "label": "t:sections.stone_pdp_size_chart.blocks.row.settings.measurement.label",
          "info": "t:sections.stone_pdp_size_chart.blocks.row.settings.measurement.info"
        },
        {
          "type": "text",
          "id": "note",
          "label": "t:sections.stone_pdp_size_chart.blocks.row.settings.note.label",
          "info": "t:sections.stone_pdp_size_chart.blocks.row.settings.note.info"
        }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  },
  "presets": [
    {
      "name": "t:sections.stone_pdp_size_chart.name",
      "blocks": [
        {
          "type": "row"
        },
        {
          "type": "row"
        },
        {
          "type": "row"
        }
      ]
    }
  ]
}
{% endschema %}
