{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_rendered_blocks = 0

  capture stone_stack_items
    for block in section.blocks
      capture stone_block_content
        case block.type
          when 'heading'
            assign stone_block_text = block.settings.text | strip
            if stone_block_text != blank
              echo '<h3 class="stone-utility-stack__heading">'
              echo stone_block_text | escape
              echo '</h3>'
            endif
          when 'richtext'
            assign stone_block_body = block.settings.body
            if stone_block_body != blank
              echo '<div class="stone-richtext-flow rte">'
              echo stone_block_body
              echo '</div>'
            endif
          when 'list'
            assign stone_list_items = block.settings.items | newline_to_br | split: '<br />'
            assign stone_list_count = 0

            capture stone_list_markup
              for stone_list_item in stone_list_items
                assign stone_list_item = stone_list_item | strip
                if stone_list_item != blank
                  assign stone_list_count = stone_list_count | plus: 1
                  echo '<li>'
                  echo stone_list_item | escape
                  echo '</li>'
                endif
              endfor
            endcapture

            if stone_list_count > 0
              echo '<ul class="stone-utility-stack__list">'
              echo stone_list_markup
              echo '</ul>'
            endif
        endcase
      endcapture

      if stone_block_content != blank
        assign stone_rendered_blocks = stone_rendered_blocks | plus: 1
        echo '<div class="stone-utility-stack__item stone-utility-stack__item--'
        echo block.type | escape
        echo '" '
        echo block.shopify_attributes
        echo '>'
        echo stone_block_content
        echo '</div>'
      endif
    endfor
  endcapture

  capture stone_section_content
    if stone_rendered_blocks > 0
      echo '<div class="stone-utility-stack">'
      echo stone_stack_items
      echo '</div>'
    else
      echo '<p class="stone-utility-stack__empty">'
      echo 'sections.stone_utility_block_stack.empty' | t
      echo '</p>'
    endif
  endcapture

  render 'stone-section-shell', section: section, heading: stone_heading, content: stone_section_content, width: section.settings.width_mode, spacing: section.settings.spacing_mode, shell_class: 'stone-utility-block-stack'
-%}

{% schema %}
{
  "name": "t:sections.stone_utility_block_stack.name",
  "tag": "section",
  "class": "shopify-section--stone-utility-block-stack",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_utility_block_stack.settings.heading.label",
      "info": "t:sections.stone_utility_block_stack.settings.heading.info"
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_utility_block_stack.settings.width_mode.label",
      "info": "t:sections.stone_utility_block_stack.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_utility_block_stack.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_utility_block_stack.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_utility_block_stack.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_utility_block_stack.settings.spacing_mode.label",
      "info": "t:sections.stone_utility_block_stack.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_utility_block_stack.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_utility_block_stack.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_utility_block_stack.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:sections.stone_utility_block_stack.blocks.heading.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.stone_utility_block_stack.blocks.heading.settings.text.label",
          "info": "t:sections.stone_utility_block_stack.blocks.heading.settings.text.info"
        }
      ]
    },
    {
      "type": "richtext",
      "name": "t:sections.stone_utility_block_stack.blocks.richtext.name",
      "settings": [
        {
          "type": "richtext",
          "id": "body",
          "label": "t:sections.stone_utility_block_stack.blocks.richtext.settings.body.label",
          "info": "t:sections.stone_utility_block_stack.blocks.richtext.settings.body.info"
        }
      ]
    },
    {
      "type": "list",
      "name": "t:sections.stone_utility_block_stack.blocks.list.name",
      "settings": [
        {
          "type": "textarea",
          "id": "items",
          "label": "t:sections.stone_utility_block_stack.blocks.list.settings.items.label",
          "info": "t:sections.stone_utility_block_stack.blocks.list.settings.items.info"
        }
      ]
    }
  ]
}
{% endschema %}
