{%- liquid
  assign stone_show_description = section.settings.show_description
  assign stone_show_sort = section.settings.show_sort
  assign stone_products_per_page = section.settings.products_per_page | default: 24
  assign stone_show_vendor = section.settings.show_vendor
  assign stone_show_price = section.settings.show_price
  assign stone_collection_description = collection.description | strip_html | strip
  assign stone_current_sort = collection.sort_by | default: collection.default_sort_by
-%}

{%- paginate collection.products by stone_products_per_page -%}
  {%- capture stone_section_content -%}
    <div class="stone-main-collection">
      <div class="stone-main-collection__header">
        <p class="stone-main-collection__eyebrow">
          {{ 'sections.stone_main_collection.collection_label' | t }}
        </p>
        <h1 class="stone-main-collection__title">{{ collection.title | escape }}</h1>

        {%- if stone_show_description and stone_collection_description != blank -%}
          <div class="stone-main-collection__description rte">
            {{ collection.description }}
          </div>
        {%- endif -%}

        <p class="stone-main-collection__count">
          {{ 'sections.stone_main_collection.product_count' | t: count: collection.all_products_count }}
        </p>
      </div>

      {%- if stone_show_sort and collection.sort_options.size > 1 -%}
        <form class="stone-main-collection__sort" action="{{ collection.url }}" method="get">
          <label class="stone-main-collection__sort-label" for="StoneCollectionSort">
            {{ 'sections.stone_main_collection.sort_label' | t }}
          </label>
          <select id="StoneCollectionSort" class="stone-main-collection__sort-select" name="sort_by">
            {%- for option in collection.sort_options -%}
              <option
                value="{{ option.value | escape }}"
                {%- if option.value == stone_current_sort %} selected{% endif -%}
              >
                {{ option.name | escape }}
              </option>
            {%- endfor -%}
          </select>
          <button class="stone-main-collection__sort-submit" type="submit">
            {{ 'sections.stone_main_collection.sort_submit' | t }}
          </button>
        </form>
      {%- endif -%}

      {%- if collection.all_products_count > 0 -%}
        <div class="stone-main-collection__grid">
          {%- for product in collection.products -%}
            {%- render 'stone-product-card',
              product: product,
              show_vendor: stone_show_vendor,
              show_price: stone_show_price,
              surface_style: 'outline'
            -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="stone-main-collection__empty">
          {{ 'sections.stone_main_collection.empty' | t }}
        </p>
      {%- endif -%}

      {%- if paginate.pages > 1 -%}
        <nav class="stone-main-collection__pagination" aria-label="{{ 'sections.stone_main_collection.pagination_label' | t }}">
          {%- if paginate.previous -%}
            <a class="stone-main-collection__pagination-link" href="{{ paginate.previous.url }}">
              {{ 'sections.stone_main_collection.previous_page' | t }}
            </a>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a class="stone-main-collection__pagination-link" href="{{ part.url }}">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}
              <span class="stone-main-collection__pagination-current" aria-current="page">{{ part.title }}</span>
            {%- else -%}
              <span class="stone-main-collection__pagination-gap">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a class="stone-main-collection__pagination-link" href="{{ paginate.next.url }}">
              {{ 'sections.stone_main_collection.next_page' | t }}
            </a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    </div>
  {%- endcapture -%}

  {%- render 'stone-section-shell',
    section: section,
    heading: '',
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-main-collection-shell'
  -%}
{%- endpaginate -%}

{% schema %}
{
  "name": "t:sections.stone_main_collection.name",
  "tag": "section",
  "class": "shopify-section--stone-main-collection",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "t:sections.stone_main_collection.settings.show_description.label",
      "info": "t:sections.stone_main_collection.settings.show_description.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "t:sections.stone_main_collection.settings.show_sort.label",
      "info": "t:sections.stone_main_collection.settings.show_sort.info",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:sections.stone_main_collection.settings.products_per_page.label",
      "info": "t:sections.stone_main_collection.settings.products_per_page.info",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.stone_main_collection.settings.show_vendor.label",
      "info": "t:sections.stone_main_collection.settings.show_vendor.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "t:sections.stone_main_collection.settings.show_price.label",
      "info": "t:sections.stone_main_collection.settings.show_price.info",
      "default": true
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_main_collection.settings.width_mode.label",
      "info": "t:sections.stone_main_collection.settings.width_mode.info",
      "default": "wide",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_main_collection.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_main_collection.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_main_collection.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_main_collection.settings.spacing_mode.label",
      "info": "t:sections.stone_main_collection.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_main_collection.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_main_collection.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_main_collection.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ]
}
{% endschema %}
