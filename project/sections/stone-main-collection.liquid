{%- liquid
  assign stone_show_description = section.settings.show_description
  assign stone_show_filters = section.settings.show_filters
  assign stone_show_sort = section.settings.show_sort
  assign stone_products_per_page = section.settings.products_per_page | default: 24
  assign stone_show_vendor = section.settings.show_vendor
  assign stone_show_price = section.settings.show_price
  assign stone_collection_description = collection.description | strip_html | strip
  assign stone_current_sort = collection.sort_by | default: collection.default_sort_by
-%}

{%- paginate collection.products by stone_products_per_page -%}
  {%- capture stone_section_content -%}
    <div class="stone-main-collection">
      <div class="stone-main-collection__header">
        <p class="stone-main-collection__eyebrow">
          {{ 'sections.stone_main_collection.collection_label' | t }}
        </p>
        <h1 class="stone-main-collection__title">{{ collection.title | escape }}</h1>

        {%- if stone_show_description and stone_collection_description != blank -%}
          <div class="stone-main-collection__description rte">
            {{ collection.description }}
          </div>
        {%- endif -%}

        <p class="stone-main-collection__count">
          {{ 'sections.stone_main_collection.product_count' | t: count: collection.products_count }}
        </p>
      </div>

      {%- if stone_show_filters and collection.filters.size > 0 -%}
        <form class="stone-main-collection__filters" action="{{ collection.url }}" method="get">
          {%- if stone_current_sort != blank -%}
            <input type="hidden" name="sort_by" value="{{ stone_current_sort | escape }}">
          {%- endif -%}

          <div class="stone-main-collection__filters-header">
            <h2 class="stone-main-collection__filters-title">
              {{ 'sections.stone_main_collection.filters_label' | t }}
            </h2>
            <a class="stone-main-collection__filters-clear" href="{{ collection.url }}">
              {{ 'sections.stone_main_collection.filter_clear_all' | t }}
            </a>
          </div>

          <div class="stone-main-collection__filter-groups">
            {%- for filter in collection.filters -%}
              <details class="stone-main-collection__filter-group" open>
                <summary class="stone-main-collection__filter-summary">
                  <span>{{ filter.label | escape }}</span>
                  {%- if filter.active_values.size > 0 -%}
                    <span class="stone-main-collection__filter-count">
                      {{ 'sections.stone_main_collection.filter_count' | t: count: filter.active_values.size }}
                    </span>
                  {%- endif -%}
                </summary>

                <div class="stone-main-collection__filter-panel">
                  {%- if filter.active_values.size > 0 -%}
                    <a class="stone-main-collection__filter-reset" href="{{ filter.url_to_remove }}">
                      {{ 'sections.stone_main_collection.filter_reset' | t }}
                    </a>
                  {%- endif -%}

                  {%- case filter.type -%}
                    {%- when 'boolean' -%}
                      <ul class="stone-main-collection__filter-list" role="list">
                        {%- if filter.true_value -%}
                          <li class="stone-main-collection__filter-item">
                            <label class="stone-main-collection__filter-choice" for="StoneFilter-{{ filter.param_name | escape }}-true">
                              <input
                                id="StoneFilter-{{ filter.param_name | escape }}-true"
                                type="checkbox"
                                name="{{ filter.param_name }}"
                                value="{{ filter.true_value.value | escape }}"
                                {%- if filter.true_value.active %} checked{% endif -%}
                                {%- if filter.true_value.count == 0 and filter.true_value.active == false %} disabled{% endif -%}
                              >
                              <span>{{ filter.true_value.label | escape }}</span>
                              <span class="stone-main-collection__filter-result-count">{{ filter.true_value.count }}</span>
                            </label>
                          </li>
                        {%- endif -%}
                        {%- if filter.false_value -%}
                          <li class="stone-main-collection__filter-item">
                            <label class="stone-main-collection__filter-choice" for="StoneFilter-{{ filter.param_name | escape }}-false">
                              <input
                                id="StoneFilter-{{ filter.param_name | escape }}-false"
                                type="checkbox"
                                name="{{ filter.param_name }}"
                                value="{{ filter.false_value.value | escape }}"
                                {%- if filter.false_value.active %} checked{% endif -%}
                                {%- if filter.false_value.count == 0 and filter.false_value.active == false %} disabled{% endif -%}
                              >
                              <span>{{ filter.false_value.label | escape }}</span>
                              <span class="stone-main-collection__filter-result-count">{{ filter.false_value.count }}</span>
                            </label>
                          </li>
                        {%- endif -%}
                      </ul>
                    {%- when 'price_range' -%}
                      <div class="stone-main-collection__price-range">
                        <label class="stone-main-collection__price-field" for="StoneFilter-{{ filter.min_value.param_name | escape }}">
                          <span>{{ 'sections.stone_main_collection.filter_min' | t }}</span>
                          <input
                            id="StoneFilter-{{ filter.min_value.param_name | escape }}"
                            type="number"
                            inputmode="decimal"
                            name="{{ filter.min_value.param_name }}"
                            value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          >
                        </label>
                        <label class="stone-main-collection__price-field" for="StoneFilter-{{ filter.max_value.param_name | escape }}">
                          <span>{{ 'sections.stone_main_collection.filter_max' | t }}</span>
                          <input
                            id="StoneFilter-{{ filter.max_value.param_name | escape }}"
                            type="number"
                            inputmode="decimal"
                            name="{{ filter.max_value.param_name }}"
                            value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          >
                        </label>
                      </div>
                    {%- else -%}
                      <ul class="stone-main-collection__filter-list" role="list">
                        {%- for filter_value in filter.values -%}
                          <li class="stone-main-collection__filter-item">
                            <label class="stone-main-collection__filter-choice" for="StoneFilter-{{ filter.param_name | escape }}-{{ forloop.index }}">
                              <input
                                id="StoneFilter-{{ filter.param_name | escape }}-{{ forloop.index }}"
                                type="checkbox"
                                name="{{ filter.param_name }}"
                                value="{{ filter_value.value | escape }}"
                                {%- if filter_value.active %} checked{% endif -%}
                                {%- if filter_value.count == 0 and filter_value.active == false %} disabled{% endif -%}
                              >
                              <span>{{ filter_value.label | escape }}</span>
                              <span class="stone-main-collection__filter-result-count">{{ filter_value.count }}</span>
                            </label>
                          </li>
                        {%- endfor -%}
                      </ul>
                  {%- endcase -%}
                </div>
              </details>
            {%- endfor -%}
          </div>

          <button class="stone-main-collection__filters-submit" type="submit">
            {{ 'sections.stone_main_collection.filter_apply' | t }}
          </button>
        </form>
      {%- endif -%}

      {%- if stone_show_sort and collection.sort_options.size > 1 -%}
        <form class="stone-main-collection__sort" action="{{ collection.url }}" method="get">
          {%- for filter in collection.filters -%}
            {%- if filter.type == 'price_range' -%}
              {%- if filter.min_value.value != blank -%}
                <input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}">
              {%- endif -%}
              {%- if filter.max_value.value != blank -%}
                <input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}">
              {%- endif -%}
            {%- else -%}
              {%- for filter_value in filter.active_values -%}
                <input type="hidden" name="{{ filter.param_name }}" value="{{ filter_value.value | escape }}">
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}

          <label class="stone-main-collection__sort-label" for="StoneCollectionSort">
            {{ 'sections.stone_main_collection.sort_label' | t }}
          </label>
          <select id="StoneCollectionSort" class="stone-main-collection__sort-select" name="sort_by">
            {%- for option in collection.sort_options -%}
              <option
                value="{{ option.value | escape }}"
                {%- if option.value == stone_current_sort %} selected{% endif -%}
              >
                {{ option.name | escape }}
              </option>
            {%- endfor -%}
          </select>
          <button class="stone-main-collection__sort-submit" type="submit">
            {{ 'sections.stone_main_collection.sort_submit' | t }}
          </button>
        </form>
      {%- endif -%}

      {%- if collection.products_count > 0 -%}
        <div class="stone-main-collection__grid">
          {%- for product in collection.products -%}
            {%- render 'stone-product-card',
              product: product,
              show_vendor: stone_show_vendor,
              show_price: stone_show_price,
              surface_style: 'outline'
            -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="stone-main-collection__empty">
          {{ 'sections.stone_main_collection.empty' | t }}
        </p>
      {%- endif -%}

      {%- if paginate.pages > 1 -%}
        <nav class="stone-main-collection__pagination" aria-label="{{ 'sections.stone_main_collection.pagination_label' | t }}">
          {%- if paginate.previous -%}
            <a class="stone-main-collection__pagination-link" href="{{ paginate.previous.url }}">
              {{ 'sections.stone_main_collection.previous_page' | t }}
            </a>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a class="stone-main-collection__pagination-link" href="{{ part.url }}">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}
              <span class="stone-main-collection__pagination-current" aria-current="page">{{ part.title }}</span>
            {%- else -%}
              <span class="stone-main-collection__pagination-gap">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a class="stone-main-collection__pagination-link" href="{{ paginate.next.url }}">
              {{ 'sections.stone_main_collection.next_page' | t }}
            </a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    </div>
  {%- endcapture -%}

  {%- render 'stone-section-shell',
    section: section,
    heading: '',
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-main-collection-shell'
  -%}
{%- endpaginate -%}

{% schema %}
{
  "name": "t:sections.stone_main_collection.name",
  "tag": "section",
  "class": "shopify-section--stone-main-collection",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "t:sections.stone_main_collection.settings.show_description.label",
      "info": "t:sections.stone_main_collection.settings.show_description.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "t:sections.stone_main_collection.settings.show_sort.label",
      "info": "t:sections.stone_main_collection.settings.show_sort.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "t:sections.stone_main_collection.settings.show_filters.label",
      "info": "t:sections.stone_main_collection.settings.show_filters.info",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:sections.stone_main_collection.settings.products_per_page.label",
      "info": "t:sections.stone_main_collection.settings.products_per_page.info",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.stone_main_collection.settings.show_vendor.label",
      "info": "t:sections.stone_main_collection.settings.show_vendor.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "t:sections.stone_main_collection.settings.show_price.label",
      "info": "t:sections.stone_main_collection.settings.show_price.info",
      "default": true
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_main_collection.settings.width_mode.label",
      "info": "t:sections.stone_main_collection.settings.width_mode.info",
      "default": "wide",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_main_collection.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_main_collection.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_main_collection.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_main_collection.settings.spacing_mode.label",
      "info": "t:sections.stone_main_collection.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_main_collection.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_main_collection.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_main_collection.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ]
}
{% endschema %}
