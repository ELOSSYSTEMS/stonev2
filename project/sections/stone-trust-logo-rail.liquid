{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_intro = section.settings.intro
  assign stone_intro_plain = stone_intro | strip_html | strip
  assign stone_surface_style = section.settings.surface_style | default: 'outline'
  assign stone_mark_tone = section.settings.mark_tone | default: 'muted'

  capture stone_section_content
    echo '<div class="stone-trust-logo-rail stone-trust-logo-rail--'
    echo stone_surface_style | escape
    echo ' stone-trust-logo-rail--'
    echo stone_mark_tone | escape
    echo '">'

    if stone_intro_plain != blank
      echo '<div class="stone-trust-logo-rail__intro stone-richtext-flow rte">'
      echo stone_intro
      echo '</div>'
    endif

    if section.blocks.size > 0
      echo '<div class="stone-trust-logo-rail__items">'
      for block in section.blocks
        assign stone_image = block.settings.image
        assign stone_alt = block.settings.alt_text | strip

        echo '<div class="stone-trust-logo-rail__item"'
        echo block.shopify_attributes
        echo '>'

        if stone_image != blank
          echo '<div class="stone-trust-logo-rail__mark">'
          echo stone_image | image_url: width: 320 | image_tag: class: 'stone-trust-logo-rail__image', loading: 'lazy', widths: '120, 180, 240, 320', sizes: '(min-width: 48rem) 12rem, 40vw', alt: stone_alt
          echo '</div>'
        else
          echo '<p class="stone-trust-logo-rail__empty-item">'
          echo 'sections.stone_trust_logo_rail.blocks.item.empty_image' | t
          echo '</p>'
        endif

        echo '</div>'
      endfor
      echo '</div>'
    else
      echo '<p class="stone-trust-logo-rail__empty">'
      echo 'sections.stone_trust_logo_rail.empty' | t
      echo '</p>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell',
    section: section,
    heading: stone_heading,
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-trust-logo-rail-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_trust_logo_rail.name",
  "tag": "section",
  "class": "shopify-section--stone-trust-logo-rail",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_trust_logo_rail.settings.heading.label",
      "info": "t:sections.stone_trust_logo_rail.settings.heading.info"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.stone_trust_logo_rail.settings.intro.label",
      "info": "t:sections.stone_trust_logo_rail.settings.intro.info"
    },
    {
      "type": "select",
      "id": "surface_style",
      "label": "t:sections.stone_trust_logo_rail.settings.surface_style.label",
      "info": "t:sections.stone_trust_logo_rail.settings.surface_style.info",
      "default": "outline",
      "options": [
        {
          "value": "outline",
          "label": "t:sections.stone_trust_logo_rail.settings.surface_style.options.outline.label"
        },
        {
          "value": "soft",
          "label": "t:sections.stone_trust_logo_rail.settings.surface_style.options.soft.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "mark_tone",
      "label": "t:sections.stone_trust_logo_rail.settings.mark_tone.label",
      "info": "t:sections.stone_trust_logo_rail.settings.mark_tone.info",
      "default": "muted",
      "options": [
        {
          "value": "muted",
          "label": "t:sections.stone_trust_logo_rail.settings.mark_tone.options.muted.label"
        },
        {
          "value": "original",
          "label": "t:sections.stone_trust_logo_rail.settings.mark_tone.options.original.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_trust_logo_rail.settings.width_mode.label",
      "info": "t:sections.stone_trust_logo_rail.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_trust_logo_rail.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_trust_logo_rail.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_trust_logo_rail.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_trust_logo_rail.settings.spacing_mode.label",
      "info": "t:sections.stone_trust_logo_rail.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_trust_logo_rail.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_trust_logo_rail.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_trust_logo_rail.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "t:sections.stone_trust_logo_rail.blocks.item.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.stone_trust_logo_rail.blocks.item.settings.image.label",
          "info": "t:sections.stone_trust_logo_rail.blocks.item.settings.image.info"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "t:sections.stone_trust_logo_rail.blocks.item.settings.alt_text.label",
          "info": "t:sections.stone_trust_logo_rail.blocks.item.settings.alt_text.info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stone_trust_logo_rail.name",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
