{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_media_video = section.settings.media_video
  assign stone_first_product_handle = section.settings.first_product
  assign stone_second_product_handle = section.settings.second_product
  assign stone_first_product = all_products[stone_first_product_handle]
  assign stone_second_product = all_products[stone_second_product_handle]
  assign stone_marker_one_x = section.settings.marker_one_x | default: 28
  assign stone_marker_one_y = section.settings.marker_one_y | default: 42
  assign stone_marker_two_x = section.settings.marker_two_x | default: 72
  assign stone_marker_two_y = section.settings.marker_two_y | default: 58
  assign stone_ready = false

  if stone_media_video != blank and stone_first_product_handle != blank and stone_second_product_handle != blank and stone_first_product != blank and stone_second_product != blank
    assign stone_ready = true
  endif

  capture stone_section_content
    echo '<div class="stone-shoppable-media-motion-story">'

    if stone_ready
      echo '<div class="stone-shoppable-media-motion-story__media-wrap">'
      echo '<figure class="stone-shoppable-media-motion-story__media">'
      echo stone_media_video | video_tag: class: 'stone-shoppable-media-motion-story__video', controls: true, playsinline: true, preload: 'metadata', image_size: '1600x'

      echo '<a class="stone-shoppable-media-motion-story__marker stone-shoppable-media-motion-story__marker--one" href="#StoneShoppableMotionProductOne-'
      echo section.id | escape
      echo '" style="inset-inline-start: '
      echo stone_marker_one_x | escape
      echo '%; top: '
      echo stone_marker_one_y | escape
      echo '%;" aria-label="'
      echo stone_first_product.title | escape
      echo '">1</a>'

      echo '<a class="stone-shoppable-media-motion-story__marker stone-shoppable-media-motion-story__marker--two" href="#StoneShoppableMotionProductTwo-'
      echo section.id | escape
      echo '" style="inset-inline-start: '
      echo stone_marker_two_x | escape
      echo '%; top: '
      echo stone_marker_two_y | escape
      echo '%;" aria-label="'
      echo stone_second_product.title | escape
      echo '">2</a>'
      echo '</figure>'
      echo '</div>'

      echo '<div class="stone-shoppable-media-motion-story__products">'
      echo '<div id="StoneShoppableMotionProductOne-'
      echo section.id | escape
      echo '" class="stone-shoppable-media-motion-story__product stone-shoppable-media-motion-story__product--one">'
      render 'stone-product-card', product: stone_first_product
      echo '</div>'
      echo '<div id="StoneShoppableMotionProductTwo-'
      echo section.id | escape
      echo '" class="stone-shoppable-media-motion-story__product stone-shoppable-media-motion-story__product--two">'
      render 'stone-product-card', product: stone_second_product
      echo '</div>'
      echo '</div>'
    else
      echo '<p class="stone-shoppable-media-motion-story__empty">'
      echo 'sections.stone_shoppable_media_motion_story.empty_state' | t
      echo '</p>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell', section: section, heading: stone_heading, content: stone_section_content, width: section.settings.width_mode, spacing: section.settings.spacing_mode, shell_class: 'stone-shoppable-media-motion-story-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_shoppable_media_motion_story.name",
  "tag": "section",
  "class": "shopify-section--stone-shoppable-media-motion-story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_shoppable_media_motion_story.settings.heading.label",
      "info": "t:sections.stone_shoppable_media_motion_story.settings.heading.info"
    },
    {
      "type": "video",
      "id": "media_video",
      "label": "t:sections.stone_shoppable_media_motion_story.settings.media_video.label",
      "info": "t:sections.stone_shoppable_media_motion_story.settings.media_video.info"
    },
    {
      "type": "product",
      "id": "first_product",
      "label": "t:sections.stone_shoppable_media_motion_story.settings.first_product.label",
      "info": "t:sections.stone_shoppable_media_motion_story.settings.first_product.info"
    },
    {
      "type": "product",
      "id": "second_product",
      "label": "t:sections.stone_shoppable_media_motion_story.settings.second_product.label",
      "info": "t:sections.stone_shoppable_media_motion_story.settings.second_product.info"
    },
    {
      "type": "range",
      "id": "marker_one_x",
      "label": "t:sections.stone_shoppable_media_motion_story.settings.marker_one_x.label",
      "info": "t:sections.stone_shoppable_media_motion_story.settings.marker_one_x.info",
      "min": 5,
      "max": 95,
      "step": 1,
      "default": 28,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "marker_one_y",
      "label": "t:sections.stone_shoppable_media_motion_story.settings.marker_one_y.label",
      "info": "t:sections.stone_shoppable_media_motion_story.settings.marker_one_y.info",
      "min": 5,
      "max": 95,
      "step": 1,
      "default": 42,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "marker_two_x",
      "label": "t:sections.stone_shoppable_media_motion_story.settings.marker_two_x.label",
      "info": "t:sections.stone_shoppable_media_motion_story.settings.marker_two_x.info",
      "min": 5,
      "max": 95,
      "step": 1,
      "default": 72,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "marker_two_y",
      "label": "t:sections.stone_shoppable_media_motion_story.settings.marker_two_y.label",
      "info": "t:sections.stone_shoppable_media_motion_story.settings.marker_two_y.info",
      "min": 5,
      "max": 95,
      "step": 1,
      "default": 58,
      "unit": "%"
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_shoppable_media_motion_story.settings.width_mode.label",
      "info": "t:sections.stone_shoppable_media_motion_story.settings.width_mode.info",
      "default": "wide",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_shoppable_media_motion_story.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_shoppable_media_motion_story.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_shoppable_media_motion_story.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_shoppable_media_motion_story.settings.spacing_mode.label",
      "info": "t:sections.stone_shoppable_media_motion_story.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_shoppable_media_motion_story.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_shoppable_media_motion_story.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_shoppable_media_motion_story.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stone_shoppable_media_motion_story.name"
    }
  ]
}
{% endschema %}
