{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_label = section.settings.label | strip
  assign stone_size_mode = section.settings.size_mode | default: 'medium'
  assign stone_boundary_mode = section.settings.boundary_mode | default: 'none'

  capture stone_section_content
    echo '<div class="stone-utility-spacer stone-utility-spacer--'
    echo stone_size_mode | escape
    echo ' stone-utility-spacer--'
    echo stone_boundary_mode | escape
    echo '">'

    if stone_label != blank
      echo '<p class="stone-utility-spacer__label">'
      echo stone_label | escape
      echo '</p>'
    endif

    echo '<div class="stone-utility-spacer__lane" aria-hidden="true"></div>'
    echo '</div>'
  endcapture

  render 'stone-section-shell',
    section: section,
    heading: stone_heading,
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-utility-spacer-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_utility_spacer.name",
  "tag": "section",
  "class": "shopify-section--stone-utility-spacer",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_utility_spacer.settings.heading.label",
      "info": "t:sections.stone_utility_spacer.settings.heading.info"
    },
    {
      "type": "text",
      "id": "label",
      "label": "t:sections.stone_utility_spacer.settings.label.label",
      "info": "t:sections.stone_utility_spacer.settings.label.info"
    },
    {
      "type": "select",
      "id": "size_mode",
      "label": "t:sections.stone_utility_spacer.settings.size_mode.label",
      "info": "t:sections.stone_utility_spacer.settings.size_mode.info",
      "default": "medium",
      "options": [
        {
          "value": "small",
          "label": "t:sections.stone_utility_spacer.settings.size_mode.options.small.label"
        },
        {
          "value": "medium",
          "label": "t:sections.stone_utility_spacer.settings.size_mode.options.medium.label"
        },
        {
          "value": "large",
          "label": "t:sections.stone_utility_spacer.settings.size_mode.options.large.label"
        },
        {
          "value": "xlarge",
          "label": "t:sections.stone_utility_spacer.settings.size_mode.options.xlarge.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "boundary_mode",
      "label": "t:sections.stone_utility_spacer.settings.boundary_mode.label",
      "info": "t:sections.stone_utility_spacer.settings.boundary_mode.info",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "t:sections.stone_utility_spacer.settings.boundary_mode.options.none.label"
        },
        {
          "value": "top",
          "label": "t:sections.stone_utility_spacer.settings.boundary_mode.options.top.label"
        },
        {
          "value": "bottom",
          "label": "t:sections.stone_utility_spacer.settings.boundary_mode.options.bottom.label"
        },
        {
          "value": "both",
          "label": "t:sections.stone_utility_spacer.settings.boundary_mode.options.both.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_utility_spacer.settings.width_mode.label",
      "info": "t:sections.stone_utility_spacer.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_utility_spacer.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_utility_spacer.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_utility_spacer.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_utility_spacer.settings.spacing_mode.label",
      "info": "t:sections.stone_utility_spacer.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_utility_spacer.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_utility_spacer.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_utility_spacer.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ]
}
{% endschema %}
