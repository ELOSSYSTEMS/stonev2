{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_body = section.settings.body
  assign stone_cta_label = section.settings.cta_label | strip
  assign stone_cta_link = section.settings.cta_link

  capture stone_section_content
    if stone_body != blank
      echo '<div class="stone-richtext-flow rte">'
      echo stone_body
      echo '</div>'
    endif

    if stone_cta_label != blank and stone_cta_link != blank
      echo '<p class="stone-section-shell__actions">'
      echo '<a class="stone-section-shell__link" href="'
      echo stone_cta_link
      echo '">'
      echo stone_cta_label | escape
      echo '</a>'
      echo '</p>'
    endif
  endcapture

  render 'stone-section-shell',
    section: section,
    heading: stone_heading,
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-utility-richtext'
-%}

{% schema %}
{
  "name": "t:sections.stone_utility_richtext.name",
  "tag": "section",
  "class": "shopify-section--stone-utility-richtext",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_utility_richtext.settings.heading.label",
      "info": "t:sections.stone_utility_richtext.settings.heading.info"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "t:sections.stone_utility_richtext.settings.body.label",
      "info": "t:sections.stone_utility_richtext.settings.body.info"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:sections.stone_utility_richtext.settings.cta_label.label",
      "info": "t:sections.stone_utility_richtext.settings.cta_label.info"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.stone_utility_richtext.settings.cta_link.label",
      "info": "t:sections.stone_utility_richtext.settings.cta_link.info"
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_utility_richtext.settings.width_mode.label",
      "info": "t:sections.stone_utility_richtext.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_utility_richtext.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_utility_richtext.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_utility_richtext.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_utility_richtext.settings.spacing_mode.label",
      "info": "t:sections.stone_utility_richtext.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_utility_richtext.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_utility_richtext.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_utility_richtext.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ]
}
{% endschema %}
