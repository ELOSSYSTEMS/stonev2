{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_primary_count = 0
  assign stone_secondary_count = 0
  assign stone_primary_items = ''
  assign stone_secondary_items = ''

  for block in section.blocks
    assign stone_region = block.settings.region | default: 'primary'

    capture stone_block_content
      case block.type
        when 'heading'
          assign stone_block_text = block.settings.text | strip
          if stone_block_text != blank
            echo '<h3 class="stone-utility-stack__heading">'
            echo stone_block_text | escape
            echo '</h3>'
          endif
        when 'richtext'
          assign stone_block_body = block.settings.body
          if stone_block_body != blank
            echo '<div class="stone-richtext-flow rte">'
            echo stone_block_body
            echo '</div>'
          endif
        when 'list'
          assign stone_list_items = block.settings.items | newline_to_br | split: '<br />'
          assign stone_list_count = 0

          capture stone_list_markup
            for stone_list_item in stone_list_items
              assign stone_list_item = stone_list_item | strip
              if stone_list_item != blank
                assign stone_list_count = stone_list_count | plus: 1
                echo '<li>'
                echo stone_list_item | escape
                echo '</li>'
              endif
            endfor
          endcapture

          if stone_list_count > 0
            echo '<ul class="stone-utility-stack__list">'
            echo stone_list_markup
            echo '</ul>'
          endif
      endcase
    endcapture

    if stone_block_content != blank
      capture stone_item_markup
        echo '<div class="stone-utility-stack__item stone-utility-stack__item--'
        echo block.type | escape
        echo '" '
        echo block.shopify_attributes
        echo '>'
        echo stone_block_content
        echo '</div>'
      endcapture

      if stone_region == 'secondary'
        assign stone_secondary_count = stone_secondary_count | plus: 1
        capture stone_secondary_items
          echo stone_secondary_items
          echo stone_item_markup
        endcapture
      else
        assign stone_primary_count = stone_primary_count | plus: 1
        capture stone_primary_items
          echo stone_primary_items
          echo stone_item_markup
        endcapture
      endif
    endif
  endfor

  capture stone_section_content
    echo '<div class="stone-utility-layout">'

    echo '<div class="stone-utility-layout__region stone-utility-layout__region--primary" aria-label="'
    echo 'sections.stone_utility_layout_composition.regions.primary.label' | t | escape
    echo '">'
    if stone_primary_count > 0
      echo '<div class="stone-utility-layout__items">'
      echo stone_primary_items
      echo '</div>'
    else
      echo '<p class="stone-utility-layout__empty">'
      echo 'sections.stone_utility_layout_composition.empty_region' | t
      echo '</p>'
    endif
    echo '</div>'

    echo '<div class="stone-utility-layout__region stone-utility-layout__region--secondary" aria-label="'
    echo 'sections.stone_utility_layout_composition.regions.secondary.label' | t | escape
    echo '">'
    if stone_secondary_count > 0
      echo '<div class="stone-utility-layout__items">'
      echo stone_secondary_items
      echo '</div>'
    else
      echo '<p class="stone-utility-layout__empty">'
      echo 'sections.stone_utility_layout_composition.empty_region' | t
      echo '</p>'
    endif
    echo '</div>'

    echo '</div>'

    if stone_primary_count == 0 and stone_secondary_count == 0
      echo '<p class="stone-utility-layout__empty">'
      echo 'sections.stone_utility_layout_composition.empty' | t
      echo '</p>'
    endif
  endcapture

  render 'stone-section-shell',
    section: section,
    heading: stone_heading,
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-utility-layout-composition'
-%}

{% schema %}
{
  "name": "t:sections.stone_utility_layout_composition.name",
  "tag": "section",
  "class": "shopify-section--stone-utility-layout-composition",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_utility_layout_composition.settings.heading.label",
      "info": "t:sections.stone_utility_layout_composition.settings.heading.info"
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_utility_layout_composition.settings.width_mode.label",
      "info": "t:sections.stone_utility_layout_composition.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_utility_layout_composition.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_utility_layout_composition.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_utility_layout_composition.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_utility_layout_composition.settings.spacing_mode.label",
      "info": "t:sections.stone_utility_layout_composition.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_utility_layout_composition.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_utility_layout_composition.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_utility_layout_composition.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:sections.stone_utility_layout_composition.blocks.heading.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.stone_utility_layout_composition.blocks.heading.settings.text.label",
          "info": "t:sections.stone_utility_layout_composition.blocks.heading.settings.text.info"
        },
        {
          "type": "select",
          "id": "region",
          "label": "t:sections.stone_utility_layout_composition.blocks.heading.settings.region.label",
          "info": "t:sections.stone_utility_layout_composition.blocks.heading.settings.region.info",
          "default": "primary",
          "options": [
            {
              "value": "primary",
              "label": "t:sections.stone_utility_layout_composition.blocks.heading.settings.region.options.primary.label"
            },
            {
              "value": "secondary",
              "label": "t:sections.stone_utility_layout_composition.blocks.heading.settings.region.options.secondary.label"
            }
          ]
        }
      ]
    },
    {
      "type": "richtext",
      "name": "t:sections.stone_utility_layout_composition.blocks.richtext.name",
      "settings": [
        {
          "type": "richtext",
          "id": "body",
          "label": "t:sections.stone_utility_layout_composition.blocks.richtext.settings.body.label",
          "info": "t:sections.stone_utility_layout_composition.blocks.richtext.settings.body.info"
        },
        {
          "type": "select",
          "id": "region",
          "label": "t:sections.stone_utility_layout_composition.blocks.richtext.settings.region.label",
          "info": "t:sections.stone_utility_layout_composition.blocks.richtext.settings.region.info",
          "default": "primary",
          "options": [
            {
              "value": "primary",
              "label": "t:sections.stone_utility_layout_composition.blocks.richtext.settings.region.options.primary.label"
            },
            {
              "value": "secondary",
              "label": "t:sections.stone_utility_layout_composition.blocks.richtext.settings.region.options.secondary.label"
            }
          ]
        }
      ]
    },
    {
      "type": "list",
      "name": "t:sections.stone_utility_layout_composition.blocks.list.name",
      "settings": [
        {
          "type": "textarea",
          "id": "items",
          "label": "t:sections.stone_utility_layout_composition.blocks.list.settings.items.label",
          "info": "t:sections.stone_utility_layout_composition.blocks.list.settings.items.info"
        },
        {
          "type": "select",
          "id": "region",
          "label": "t:sections.stone_utility_layout_composition.blocks.list.settings.region.label",
          "info": "t:sections.stone_utility_layout_composition.blocks.list.settings.region.info",
          "default": "primary",
          "options": [
            {
              "value": "primary",
              "label": "t:sections.stone_utility_layout_composition.blocks.list.settings.region.options.primary.label"
            },
            {
              "value": "secondary",
              "label": "t:sections.stone_utility_layout_composition.blocks.list.settings.region.options.secondary.label"
            }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
