{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_eyebrow = section.settings.eyebrow | strip
  assign stone_quote = section.settings.quote
  assign stone_quote_plain = stone_quote | strip_html | strip
  assign stone_body = section.settings.body
  assign stone_body_plain = stone_body | strip_html | strip
  assign stone_attribution = section.settings.attribution | strip
  assign stone_surface_style = section.settings.surface_style | default: 'outline'
  assign stone_text_align = section.settings.text_align | default: 'start'

  capture stone_section_content
    echo '<div class="stone-editorial-quote stone-editorial-quote--'
    echo stone_surface_style | escape
    echo ' stone-editorial-quote--'
    echo stone_text_align | escape
    echo '">'

    if stone_eyebrow != blank
      echo '<p class="stone-editorial-quote__eyebrow">'
      echo stone_eyebrow | escape
      echo '</p>'
    endif

    if stone_quote_plain != blank
      echo '<blockquote class="stone-editorial-quote__quote stone-richtext-flow rte">'
      echo stone_quote
      echo '</blockquote>'
    else
      echo '<p class="stone-editorial-quote__empty">'
      echo 'sections.stone_editorial_quote.empty_quote' | t
      echo '</p>'
    endif

    if stone_body_plain != blank
      echo '<div class="stone-editorial-quote__body stone-richtext-flow rte">'
      echo stone_body
      echo '</div>'
    endif

    if stone_attribution != blank
      echo '<p class="stone-editorial-quote__attribution">'
      echo stone_attribution | escape
      echo '</p>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell', section: section, heading: stone_heading, content: stone_section_content, width: section.settings.width_mode, spacing: section.settings.spacing_mode, shell_class: 'stone-editorial-quote-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_editorial_quote.name",
  "tag": "section",
  "class": "shopify-section--stone-editorial-quote",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_editorial_quote.settings.heading.label",
      "info": "t:sections.stone_editorial_quote.settings.heading.info"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.stone_editorial_quote.settings.eyebrow.label",
      "info": "t:sections.stone_editorial_quote.settings.eyebrow.info"
    },
    {
      "type": "richtext",
      "id": "quote",
      "label": "t:sections.stone_editorial_quote.settings.quote.label",
      "info": "t:sections.stone_editorial_quote.settings.quote.info"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "t:sections.stone_editorial_quote.settings.body.label",
      "info": "t:sections.stone_editorial_quote.settings.body.info"
    },
    {
      "type": "text",
      "id": "attribution",
      "label": "t:sections.stone_editorial_quote.settings.attribution.label",
      "info": "t:sections.stone_editorial_quote.settings.attribution.info"
    },
    {
      "type": "select",
      "id": "surface_style",
      "label": "t:sections.stone_editorial_quote.settings.surface_style.label",
      "info": "t:sections.stone_editorial_quote.settings.surface_style.info",
      "default": "outline",
      "options": [
        {
          "value": "outline",
          "label": "t:sections.stone_editorial_quote.settings.surface_style.options.outline.label"
        },
        {
          "value": "soft",
          "label": "t:sections.stone_editorial_quote.settings.surface_style.options.soft.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "t:sections.stone_editorial_quote.settings.text_align.label",
      "info": "t:sections.stone_editorial_quote.settings.text_align.info",
      "default": "start",
      "options": [
        {
          "value": "start",
          "label": "t:sections.stone_editorial_quote.settings.text_align.options.start.label"
        },
        {
          "value": "center",
          "label": "t:sections.stone_editorial_quote.settings.text_align.options.center.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_editorial_quote.settings.width_mode.label",
      "info": "t:sections.stone_editorial_quote.settings.width_mode.info",
      "default": "narrow",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_editorial_quote.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_editorial_quote.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_editorial_quote.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_editorial_quote.settings.spacing_mode.label",
      "info": "t:sections.stone_editorial_quote.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_editorial_quote.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_editorial_quote.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_editorial_quote.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stone_editorial_quote.name"
    }
  ]
}
{% endschema %}
