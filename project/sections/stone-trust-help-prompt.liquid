{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_eyebrow = section.settings.eyebrow | strip
  assign stone_body = section.settings.body
  assign stone_body_plain = stone_body | strip_html | strip
  assign stone_note = section.settings.note | strip
  assign stone_primary_action_label = section.settings.primary_action_label | strip
  assign stone_primary_action_link = section.settings.primary_action_link
  assign stone_secondary_action_label = section.settings.secondary_action_label | strip
  assign stone_secondary_action_link = section.settings.secondary_action_link
  assign stone_surface_style = section.settings.surface_style | default: 'outline'
  assign stone_layout_mode = section.settings.layout_mode | default: 'split'

  capture stone_section_content
    echo '<div class="stone-trust-help-prompt stone-trust-help-prompt--'
    echo stone_surface_style | escape
    echo ' stone-trust-help-prompt--'
    echo stone_layout_mode | escape
    echo '">'

    echo '<div class="stone-trust-help-prompt__panel">'
    if stone_eyebrow != blank
      echo '<p class="stone-trust-help-prompt__eyebrow">'
      echo stone_eyebrow | escape
      echo '</p>'
    endif

    if stone_body_plain != blank
      echo '<div class="stone-trust-help-prompt__body stone-richtext-flow rte">'
      echo stone_body
      echo '</div>'
    else
      echo '<p class="stone-trust-help-prompt__empty">'
      echo 'sections.stone_trust_help_prompt.empty' | t
      echo '</p>'
    endif

    if stone_note != blank
      echo '<p class="stone-trust-help-prompt__note">'
      echo stone_note | escape
      echo '</p>'
    endif
    echo '</div>'

    if stone_primary_action_label != blank and stone_primary_action_link != blank or stone_secondary_action_label != blank and stone_secondary_action_link != blank
      echo '<div class="stone-trust-help-prompt__actions">'
      if stone_primary_action_label != blank and stone_primary_action_link != blank
        echo '<a class="stone-trust-help-prompt__action stone-trust-help-prompt__action--primary" href="'
        echo stone_primary_action_link | escape
        echo '">'
        echo stone_primary_action_label | escape
        echo '</a>'
      endif
      if stone_secondary_action_label != blank and stone_secondary_action_link != blank
        echo '<a class="stone-trust-help-prompt__action stone-trust-help-prompt__action--secondary" href="'
        echo stone_secondary_action_link | escape
        echo '">'
        echo stone_secondary_action_label | escape
        echo '</a>'
      endif
      echo '</div>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell', section: section, heading: stone_heading, content: stone_section_content, width: section.settings.width_mode, spacing: section.settings.spacing_mode, shell_class: 'stone-trust-help-prompt-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_trust_help_prompt.name",
  "tag": "section",
  "class": "shopify-section--stone-trust-help-prompt",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_trust_help_prompt.settings.heading.label",
      "info": "t:sections.stone_trust_help_prompt.settings.heading.info"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.stone_trust_help_prompt.settings.eyebrow.label",
      "info": "t:sections.stone_trust_help_prompt.settings.eyebrow.info"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "t:sections.stone_trust_help_prompt.settings.body.label",
      "info": "t:sections.stone_trust_help_prompt.settings.body.info"
    },
    {
      "type": "text",
      "id": "note",
      "label": "t:sections.stone_trust_help_prompt.settings.note.label",
      "info": "t:sections.stone_trust_help_prompt.settings.note.info"
    },
    {
      "type": "text",
      "id": "primary_action_label",
      "label": "t:sections.stone_trust_help_prompt.settings.primary_action_label.label",
      "info": "t:sections.stone_trust_help_prompt.settings.primary_action_label.info"
    },
    {
      "type": "url",
      "id": "primary_action_link",
      "label": "t:sections.stone_trust_help_prompt.settings.primary_action_link.label",
      "info": "t:sections.stone_trust_help_prompt.settings.primary_action_link.info"
    },
    {
      "type": "text",
      "id": "secondary_action_label",
      "label": "t:sections.stone_trust_help_prompt.settings.secondary_action_label.label",
      "info": "t:sections.stone_trust_help_prompt.settings.secondary_action_label.info"
    },
    {
      "type": "url",
      "id": "secondary_action_link",
      "label": "t:sections.stone_trust_help_prompt.settings.secondary_action_link.label",
      "info": "t:sections.stone_trust_help_prompt.settings.secondary_action_link.info"
    },
    {
      "type": "select",
      "id": "surface_style",
      "label": "t:sections.stone_trust_help_prompt.settings.surface_style.label",
      "info": "t:sections.stone_trust_help_prompt.settings.surface_style.info",
      "default": "outline",
      "options": [
        {
          "value": "outline",
          "label": "t:sections.stone_trust_help_prompt.settings.surface_style.options.outline.label"
        },
        {
          "value": "soft",
          "label": "t:sections.stone_trust_help_prompt.settings.surface_style.options.soft.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "t:sections.stone_trust_help_prompt.settings.layout_mode.label",
      "info": "t:sections.stone_trust_help_prompt.settings.layout_mode.info",
      "default": "split",
      "options": [
        {
          "value": "split",
          "label": "t:sections.stone_trust_help_prompt.settings.layout_mode.options.split.label"
        },
        {
          "value": "stack",
          "label": "t:sections.stone_trust_help_prompt.settings.layout_mode.options.stack.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_trust_help_prompt.settings.width_mode.label",
      "info": "t:sections.stone_trust_help_prompt.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_trust_help_prompt.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_trust_help_prompt.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_trust_help_prompt.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_trust_help_prompt.settings.spacing_mode.label",
      "info": "t:sections.stone_trust_help_prompt.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_trust_help_prompt.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_trust_help_prompt.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_trust_help_prompt.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ]
}
{% endschema %}
