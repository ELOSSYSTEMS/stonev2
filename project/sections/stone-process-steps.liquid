{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_intro = section.settings.intro
  assign stone_intro_plain = stone_intro | strip_html | strip
  assign stone_surface_style = section.settings.surface_style | default: 'outline'
  assign stone_layout_mode = section.settings.layout_mode | default: 'stack'

  capture stone_section_content
    echo '<div class="stone-process-steps stone-process-steps--'
    echo stone_surface_style | escape
    echo ' stone-process-steps--'
    echo stone_layout_mode | escape
    echo '">'

    if stone_intro_plain != blank
      echo '<div class="stone-process-steps__intro stone-richtext-flow rte">'
      echo stone_intro
      echo '</div>'
    endif

    if section.blocks.size > 0
      echo '<ol class="stone-process-steps__items">'
      for block in section.blocks
        assign stone_title = block.settings.title | strip
        assign stone_body = block.settings.body
        assign stone_body_plain = stone_body | strip_html | strip

        if stone_title != blank or stone_body_plain != blank
          echo '<li class="stone-process-steps__item"'
          echo block.shopify_attributes
          echo '>'
          echo '<div class="stone-process-steps__index">'
          echo forloop.index
          echo '</div>'
          echo '<div class="stone-process-steps__content">'

          if stone_title != blank
            echo '<h3 class="stone-process-steps__title">'
            echo stone_title | escape
            echo '</h3>'
          else
            echo '<p class="stone-process-steps__title">'
            echo 'sections.stone_process_steps.blocks.item.fallback_title' | t
            echo '</p>'
          endif

          if stone_body_plain != blank
            echo '<div class="stone-process-steps__body stone-richtext-flow rte">'
            echo stone_body
            echo '</div>'
          endif

          echo '</div>'
          echo '</li>'
        endif
      endfor
      echo '</ol>'
    else
      echo '<p class="stone-process-steps__empty">'
      echo 'sections.stone_process_steps.empty' | t
      echo '</p>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell',
    section: section,
    heading: stone_heading,
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-process-steps-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_process_steps.name",
  "tag": "section",
  "class": "shopify-section--stone-process-steps",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_process_steps.settings.heading.label",
      "info": "t:sections.stone_process_steps.settings.heading.info"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.stone_process_steps.settings.intro.label",
      "info": "t:sections.stone_process_steps.settings.intro.info"
    },
    {
      "type": "select",
      "id": "surface_style",
      "label": "t:sections.stone_process_steps.settings.surface_style.label",
      "info": "t:sections.stone_process_steps.settings.surface_style.info",
      "default": "outline",
      "options": [
        {
          "value": "outline",
          "label": "t:sections.stone_process_steps.settings.surface_style.options.outline.label"
        },
        {
          "value": "soft",
          "label": "t:sections.stone_process_steps.settings.surface_style.options.soft.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "t:sections.stone_process_steps.settings.layout_mode.label",
      "info": "t:sections.stone_process_steps.settings.layout_mode.info",
      "default": "stack",
      "options": [
        {
          "value": "stack",
          "label": "t:sections.stone_process_steps.settings.layout_mode.options.stack.label"
        },
        {
          "value": "grid",
          "label": "t:sections.stone_process_steps.settings.layout_mode.options.grid.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_process_steps.settings.width_mode.label",
      "info": "t:sections.stone_process_steps.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_process_steps.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_process_steps.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_process_steps.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_process_steps.settings.spacing_mode.label",
      "info": "t:sections.stone_process_steps.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_process_steps.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_process_steps.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_process_steps.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "t:sections.stone_process_steps.blocks.item.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.stone_process_steps.blocks.item.settings.title.label",
          "info": "t:sections.stone_process_steps.blocks.item.settings.title.info"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "t:sections.stone_process_steps.blocks.item.settings.body.label",
          "info": "t:sections.stone_process_steps.blocks.item.settings.body.info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stone_process_steps.name",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
