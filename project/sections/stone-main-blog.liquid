{%- liquid
  assign stone_articles_per_page = section.settings.articles_per_page | default: 6
  assign stone_show_image = section.settings.show_image
  assign stone_show_excerpt = section.settings.show_excerpt
  assign stone_show_date = section.settings.show_date
-%}

{%- paginate blog.articles by stone_articles_per_page -%}
  {%- capture stone_section_content -%}
    <div class="stone-main-blog">
      <header class="stone-main-blog__header">
        <p class="stone-main-blog__eyebrow">{{ 'sections.stone_main_blog.blog_label' | t }}</p>
        <h1 class="stone-main-blog__title">{{ blog.title | escape }}</h1>
        <p class="stone-main-blog__count">{{ 'sections.stone_main_blog.article_count' | t: count: blog.articles_count }}</p>
      </header>

      {%- if blog.articles_count > 0 -%}
        <div class="stone-main-blog__grid">
          {%- for article in blog.articles -%}
            {%- liquid
              assign stone_excerpt = article.excerpt | strip_html | strip
              if stone_excerpt == blank
                assign stone_excerpt = article.content | strip_html | strip
              endif
            -%}
            <article class="stone-main-blog__card">
              {%- if stone_show_image and article.image != blank -%}
                <a class="stone-main-blog__media" href="{{ article.url | escape }}">
                  {{ article.image | image_url: width: 1000 | image_tag: class: 'stone-main-blog__image', loading: 'lazy', widths: '360, 540, 720, 1000', sizes: '(min-width: 64rem) 30vw, 100vw' }}
                </a>
              {%- endif -%}

              <div class="stone-main-blog__card-content">
                {%- if stone_show_date and article.published_at != blank -%}
                  <p class="stone-main-blog__meta">{{ article.published_at | date: '%b %d, %Y' }}</p>
                {%- endif -%}

                <h2 class="stone-main-blog__article-title">
                  <a href="{{ article.url | escape }}">{{ article.title | escape }}</a>
                </h2>

                {%- if stone_show_excerpt and stone_excerpt != blank -%}
                  <p class="stone-main-blog__excerpt">{{ stone_excerpt | truncatewords: 28 | escape }}</p>
                {%- endif -%}

                <a class="stone-main-blog__link" href="{{ article.url | escape }}">{{ 'sections.stone_main_blog.read_more' | t }}</a>
              </div>
            </article>
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="stone-main-blog__empty">{{ 'sections.stone_main_blog.empty' | t }}</p>
      {%- endif -%}

      {%- if paginate.pages > 1 -%}
        <nav class="stone-main-blog__pagination" aria-label="{{ 'sections.stone_main_blog.pagination_label' | t }}">
          {%- if paginate.previous -%}
            <a class="stone-main-blog__pagination-link" href="{{ paginate.previous.url }}">{{ 'sections.stone_main_blog.previous_page' | t }}</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a class="stone-main-blog__pagination-link" href="{{ part.url }}">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}
              <span class="stone-main-blog__pagination-current" aria-current="page">{{ part.title }}</span>
            {%- else -%}
              <span class="stone-main-blog__pagination-gap">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a class="stone-main-blog__pagination-link" href="{{ paginate.next.url }}">{{ 'sections.stone_main_blog.next_page' | t }}</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    </div>
  {%- endcapture -%}

  {%- render 'stone-section-shell',
    section: section,
    heading: '',
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-main-blog-shell'
  -%}
{%- endpaginate -%}

{% schema %}
{
  "name": "t:sections.stone_main_blog.name",
  "tag": "section",
  "class": "shopify-section--stone-main-blog",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "t:sections.stone_main_blog.settings.articles_per_page.label",
      "info": "t:sections.stone_main_blog.settings.articles_per_page.info",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:sections.stone_main_blog.settings.show_image.label",
      "info": "t:sections.stone_main_blog.settings.show_image.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "t:sections.stone_main_blog.settings.show_excerpt.label",
      "info": "t:sections.stone_main_blog.settings.show_excerpt.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "t:sections.stone_main_blog.settings.show_date.label",
      "info": "t:sections.stone_main_blog.settings.show_date.info",
      "default": true
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_main_blog.settings.width_mode.label",
      "info": "t:sections.stone_main_blog.settings.width_mode.info",
      "default": "wide",
      "options": [
        { "value": "narrow", "label": "t:sections.stone_main_blog.settings.width_mode.options.narrow.label" },
        { "value": "standard", "label": "t:sections.stone_main_blog.settings.width_mode.options.standard.label" },
        { "value": "wide", "label": "t:sections.stone_main_blog.settings.width_mode.options.wide.label" }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_main_blog.settings.spacing_mode.label",
      "info": "t:sections.stone_main_blog.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        { "value": "compact", "label": "t:sections.stone_main_blog.settings.spacing_mode.options.compact.label" },
        { "value": "standard", "label": "t:sections.stone_main_blog.settings.spacing_mode.options.standard.label" },
        { "value": "relaxed", "label": "t:sections.stone_main_blog.settings.spacing_mode.options.relaxed.label" }
      ]
    }
  ]
}
{% endschema %}
