{%- liquid
  assign stone_current_variant = product.selected_or_first_available_variant
  assign stone_show_vendor = section.settings.show_vendor
  assign stone_show_type = section.settings.show_type
  assign stone_show_quantity = section.settings.show_quantity
  assign stone_show_description = section.settings.show_description
  assign stone_product_description = product.description | strip_html | strip
  assign stone_product_available = stone_current_variant.available
-%}

{%- capture stone_section_content -%}
  <div class="stone-main-product">
    <div class="stone-main-product__media-panel">
      {%- if product.featured_media.preview_image != blank -%}
        {{ product.featured_media.preview_image | image_url: width: 1600 | image_tag: class: 'stone-main-product__image', loading: 'eager', widths: '480, 720, 960, 1200, 1600', sizes: '(min-width: 64rem) 50vw, 100vw' }}
      {%- elsif product.featured_image != blank -%}
        {{ product.featured_image | image_url: width: 1600 | image_tag: class: 'stone-main-product__image', loading: 'eager', widths: '480, 720, 960, 1200, 1600', sizes: '(min-width: 64rem) 50vw, 100vw' }}
      {%- else -%}
        <div class="stone-main-product__media-empty">
          {{ 'sections.stone_main_product.no_media' | t }}
        </div>
      {%- endif -%}
    </div>

    <div class="stone-main-product__content">
      <p class="stone-main-product__eyebrow">
        {{ 'sections.stone_main_product.product_label' | t }}
      </p>

      <h1 class="stone-main-product__title">{{ product.title | escape }}</h1>

      <div class="stone-main-product__meta">
        {%- if stone_show_vendor and product.vendor != blank -%}
          <span>{{ product.vendor | escape }}</span>
        {%- endif -%}

        {%- if stone_show_type and product.type != blank -%}
          <span>{{ product.type | escape }}</span>
        {%- endif -%}
      </div>

      {%- if stone_current_variant != blank -%}
        <p class="stone-main-product__price">{{ stone_current_variant.price | money }}</p>
      {%- endif -%}

      {%- form 'product', product, class: 'stone-main-product__form' -%}
        {%- if form.errors -%}
          <div class="stone-main-product__form-errors">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        {%- if product.has_only_default_variant -%}
          <input type="hidden" name="id" value="{{ stone_current_variant.id }}">
        {%- else -%}
          <div class="stone-main-product__field">
            <label class="stone-main-product__label" for="StoneProductVariant-{{ section.id }}">
              {{ 'sections.stone_main_product.variant_label' | t }}
            </label>
            <select id="StoneProductVariant-{{ section.id }}" class="stone-main-product__select" name="id">
              {%- for variant in product.variants -%}
                <option
                  value="{{ variant.id }}"
                  {%- if variant.id == stone_current_variant.id %} selected{% endif -%}
                  {%- unless variant.available %} disabled{% endunless -%}
                >
                  {{ variant.title | escape }} - {{ variant.price | money }}
                  {%- unless variant.available %} - {{ 'sections.stone_main_product.unavailable' | t }}{% endunless -%}
                </option>
              {%- endfor -%}
            </select>
          </div>
        {%- endif -%}

        {%- if stone_show_quantity -%}
          <div class="stone-main-product__field">
            <label class="stone-main-product__label" for="StoneProductQuantity-{{ section.id }}">
              {{ 'sections.stone_main_product.quantity_label' | t }}
            </label>
            <input id="StoneProductQuantity-{{ section.id }}" class="stone-main-product__quantity" type="number" name="quantity" value="1" min="1">
          </div>
        {%- endif -%}

        <button class="stone-main-product__submit" type="submit" name="add" {%- unless stone_product_available %} disabled{% endunless -%}>
          {%- if stone_product_available -%}
            {{ 'sections.stone_main_product.add_to_cart' | t }}
          {%- else -%}
            {{ 'sections.stone_main_product.sold_out' | t }}
          {%- endif -%}
        </button>
      {%- endform -%}

      {%- if stone_show_description and stone_product_description != blank -%}
        <div class="stone-main-product__description rte">
          {{ product.description }}
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endcapture -%}

{%- render 'stone-section-shell',
  section: section,
  heading: '',
  content: stone_section_content,
  width: section.settings.width_mode,
  spacing: section.settings.spacing_mode,
  shell_class: 'stone-main-product-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_main_product.name",
  "tag": "section",
  "class": "shopify-section--stone-main-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.stone_main_product.settings.show_vendor.label",
      "info": "t:sections.stone_main_product.settings.show_vendor.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_type",
      "label": "t:sections.stone_main_product.settings.show_type.label",
      "info": "t:sections.stone_main_product.settings.show_type.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quantity",
      "label": "t:sections.stone_main_product.settings.show_quantity.label",
      "info": "t:sections.stone_main_product.settings.show_quantity.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "t:sections.stone_main_product.settings.show_description.label",
      "info": "t:sections.stone_main_product.settings.show_description.info",
      "default": true
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_main_product.settings.width_mode.label",
      "info": "t:sections.stone_main_product.settings.width_mode.info",
      "default": "wide",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_main_product.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_main_product.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_main_product.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_main_product.settings.spacing_mode.label",
      "info": "t:sections.stone_main_product.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_main_product.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_main_product.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_main_product.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ]
}
{% endschema %}
