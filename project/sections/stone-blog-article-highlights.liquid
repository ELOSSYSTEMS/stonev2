{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_intro = section.settings.intro
  assign stone_intro_plain = stone_intro | strip_html | strip
  assign stone_blog_handle = section.settings.blog
  assign stone_selected_blog = blogs[stone_blog_handle]
  assign stone_surface_style = section.settings.surface_style | default: 'outline'

  capture stone_section_content
    echo '<div class="stone-blog-article-highlights stone-blog-article-highlights--'
    echo stone_surface_style | escape
    echo '">'

    if stone_intro_plain != blank
      echo '<div class="stone-blog-article-highlights__intro stone-richtext-flow rte">'
      echo stone_intro
      echo '</div>'
    endif

    if stone_blog_handle != blank and stone_selected_blog != blank and stone_selected_blog.articles_count > 0
      echo '<div class="stone-blog-article-highlights__layout">'

      for article in stone_selected_blog.articles limit: 1
        assign stone_lead_excerpt = article.excerpt | strip_html | strip
        if stone_lead_excerpt == blank
          assign stone_lead_excerpt = article.content | strip_html | strip
        endif

        echo '<article class="stone-blog-article-highlights__lead">'

        if article.image != blank
          echo '<a class="stone-blog-article-highlights__lead-media" href="'
          echo article.url | escape
          echo '">'
          echo article.image | image_url: width: 1200 | image_tag: class: 'stone-blog-article-highlights__lead-image', loading: 'lazy', widths: '480, 720, 960, 1200', sizes: '(min-width: 64rem) 32rem, 100vw'
          echo '</a>'
        endif

        echo '<div class="stone-blog-article-highlights__lead-content">'
        echo '<p class="stone-blog-article-highlights__blog-title">'
        echo stone_selected_blog.title | escape
        echo '</p>'
        echo '<h3 class="stone-blog-article-highlights__lead-title">'
        echo '<a href="'
        echo article.url | escape
        echo '">'
        echo article.title | escape
        echo '</a>'
        echo '</h3>'

        if stone_lead_excerpt != blank
          echo '<p class="stone-blog-article-highlights__lead-excerpt">'
          echo stone_lead_excerpt | truncatewords: 28 | escape
          echo '</p>'
        endif

        echo '<a class="stone-blog-article-highlights__lead-link" href="'
        echo article.url | escape
        echo '">'
        echo 'sections.stone_blog_article_highlights.read_more' | t
        echo '</a>'
        echo '</div>'
        echo '</article>'
      endfor

      if stone_selected_blog.articles_count > 1
        echo '<div class="stone-blog-article-highlights__secondary">'
        echo '<ul class="stone-blog-article-highlights__secondary-list">'
        for article in stone_selected_blog.articles offset: 1 limit: 2
          assign stone_secondary_excerpt = article.excerpt | strip_html | strip
          if stone_secondary_excerpt == blank
            assign stone_secondary_excerpt = article.content | strip_html | strip
          endif

          echo '<li class="stone-blog-article-highlights__secondary-item">'
          echo '<h4 class="stone-blog-article-highlights__secondary-title">'
          echo '<a href="'
          echo article.url | escape
          echo '">'
          echo article.title | escape
          echo '</a>'
          echo '</h4>'
          if stone_secondary_excerpt != blank
            echo '<p class="stone-blog-article-highlights__secondary-excerpt">'
            echo stone_secondary_excerpt | truncatewords: 18 | escape
            echo '</p>'
          endif
          echo '</li>'
        endfor
        echo '</ul>'
        echo '</div>'
      endif

      echo '</div>'
    elsif stone_blog_handle != blank and stone_selected_blog != blank
      echo '<p class="stone-blog-article-highlights__empty">'
      echo 'sections.stone_blog_article_highlights.empty_articles' | t
      echo '</p>'
    else
      echo '<p class="stone-blog-article-highlights__empty">'
      echo 'sections.stone_blog_article_highlights.empty_blog' | t
      echo '</p>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell',
    section: section,
    heading: stone_heading,
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-blog-article-highlights-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_blog_article_highlights.name",
  "tag": "section",
  "class": "shopify-section--stone-blog-article-highlights",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_blog_article_highlights.settings.heading.label",
      "info": "t:sections.stone_blog_article_highlights.settings.heading.info"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.stone_blog_article_highlights.settings.intro.label",
      "info": "t:sections.stone_blog_article_highlights.settings.intro.info"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "t:sections.stone_blog_article_highlights.settings.blog.label",
      "info": "t:sections.stone_blog_article_highlights.settings.blog.info"
    },
    {
      "type": "select",
      "id": "surface_style",
      "label": "t:sections.stone_blog_article_highlights.settings.surface_style.label",
      "info": "t:sections.stone_blog_article_highlights.settings.surface_style.info",
      "default": "outline",
      "options": [
        {
          "value": "outline",
          "label": "t:sections.stone_blog_article_highlights.settings.surface_style.options.outline.label"
        },
        {
          "value": "soft",
          "label": "t:sections.stone_blog_article_highlights.settings.surface_style.options.soft.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_blog_article_highlights.settings.width_mode.label",
      "info": "t:sections.stone_blog_article_highlights.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_blog_article_highlights.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_blog_article_highlights.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_blog_article_highlights.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_blog_article_highlights.settings.spacing_mode.label",
      "info": "t:sections.stone_blog_article_highlights.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_blog_article_highlights.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_blog_article_highlights.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_blog_article_highlights.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stone_blog_article_highlights.name"
    }
  ]
}
{% endschema %}
