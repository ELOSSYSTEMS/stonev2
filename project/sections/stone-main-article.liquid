{%- liquid
  assign stone_show_image = section.settings.show_image
  assign stone_show_author = section.settings.show_author
  assign stone_show_date = section.settings.show_date
  assign stone_show_blog_link = section.settings.show_blog_link
-%}

{%- capture stone_section_content -%}
  <article class="stone-main-article">
    <header class="stone-main-article__header">
      <p class="stone-main-article__eyebrow">{{ 'sections.stone_main_article.article_label' | t }}</p>
      <h1 class="stone-main-article__title">{{ article.title | escape }}</h1>

      <div class="stone-main-article__meta">
        {%- if stone_show_date and article.published_at != blank -%}
          <span>{{ article.published_at | date: '%b %d, %Y' }}</span>
        {%- endif -%}
        {%- if stone_show_author and article.author != blank -%}
          <span>{{ article.author | escape }}</span>
        {%- endif -%}
      </div>
    </header>

    {%- if stone_show_image and article.image != blank -%}
      <div class="stone-main-article__media">
        {{ article.image | image_url: width: 1600 | image_tag: class: 'stone-main-article__image', loading: 'eager', widths: '480, 720, 960, 1200, 1600', sizes: '(min-width: 64rem) 52rem, 100vw' }}
      </div>
    {%- endif -%}

    <div class="stone-main-article__content rte">
      {{ article.content }}
    </div>

    {%- if stone_show_blog_link and blog.url != blank -%}
      <a class="stone-main-article__blog-link" href="{{ blog.url | escape }}">
        {{ 'sections.stone_main_article.back_to_blog' | t: blog_title: blog.title }}
      </a>
    {%- endif -%}
  </article>
{%- endcapture -%}

{%- render 'stone-section-shell',
  section: section,
  heading: '',
  content: stone_section_content,
  width: section.settings.width_mode,
  spacing: section.settings.spacing_mode,
  shell_class: 'stone-main-article-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_main_article.name",
  "tag": "section",
  "class": "shopify-section--stone-main-article",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:sections.stone_main_article.settings.show_image.label",
      "info": "t:sections.stone_main_article.settings.show_image.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "t:sections.stone_main_article.settings.show_author.label",
      "info": "t:sections.stone_main_article.settings.show_author.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "t:sections.stone_main_article.settings.show_date.label",
      "info": "t:sections.stone_main_article.settings.show_date.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_blog_link",
      "label": "t:sections.stone_main_article.settings.show_blog_link.label",
      "info": "t:sections.stone_main_article.settings.show_blog_link.info",
      "default": true
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_main_article.settings.width_mode.label",
      "info": "t:sections.stone_main_article.settings.width_mode.info",
      "default": "standard",
      "options": [
        { "value": "narrow", "label": "t:sections.stone_main_article.settings.width_mode.options.narrow.label" },
        { "value": "standard", "label": "t:sections.stone_main_article.settings.width_mode.options.standard.label" },
        { "value": "wide", "label": "t:sections.stone_main_article.settings.width_mode.options.wide.label" }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_main_article.settings.spacing_mode.label",
      "info": "t:sections.stone_main_article.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        { "value": "compact", "label": "t:sections.stone_main_article.settings.spacing_mode.options.compact.label" },
        { "value": "standard", "label": "t:sections.stone_main_article.settings.spacing_mode.options.standard.label" },
        { "value": "relaxed", "label": "t:sections.stone_main_article.settings.spacing_mode.options.relaxed.label" }
      ]
    }
  ]
}
{% endschema %}
