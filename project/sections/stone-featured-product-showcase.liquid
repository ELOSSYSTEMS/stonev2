{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_intro = section.settings.intro
  assign stone_intro_plain = stone_intro | strip_html | strip
  assign stone_product_handle = section.settings.product
  assign stone_selected_product = all_products[stone_product_handle]
  assign stone_surface_style = section.settings.surface_style | default: 'outline'

  capture stone_section_content
    echo '<div class="stone-featured-product-showcase stone-featured-product-showcase--'
    echo stone_surface_style | escape
    echo '">' 

    if stone_intro_plain != blank
      echo '<div class="stone-featured-product-showcase__intro stone-richtext-flow rte">'
      echo stone_intro
      echo '</div>'
    endif

    if stone_product_handle != blank and stone_selected_product != blank
      echo '<div class="stone-featured-product-showcase__card">'
      render 'stone-product-card',
        product: stone_selected_product,
        show_vendor: section.settings.show_vendor,
        show_price: section.settings.show_price,
        show_excerpt: true,
        surface_style: stone_surface_style,
        card_emphasis: 'showcase'
      echo '</div>'
    else
      echo '<p class="stone-featured-product-showcase__empty">'
      echo 'sections.stone_featured_product_showcase.empty_product' | t
      echo '</p>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell',
    section: section,
    heading: stone_heading,
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-featured-product-showcase-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_featured_product_showcase.name",
  "tag": "section",
  "class": "shopify-section--stone-featured-product-showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_featured_product_showcase.settings.heading.label",
      "info": "t:sections.stone_featured_product_showcase.settings.heading.info"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.stone_featured_product_showcase.settings.intro.label",
      "info": "t:sections.stone_featured_product_showcase.settings.intro.info"
    },
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.stone_featured_product_showcase.settings.product.label",
      "info": "t:sections.stone_featured_product_showcase.settings.product.info"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.stone_featured_product_showcase.settings.show_vendor.label",
      "info": "t:sections.stone_featured_product_showcase.settings.show_vendor.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "t:sections.stone_featured_product_showcase.settings.show_price.label",
      "info": "t:sections.stone_featured_product_showcase.settings.show_price.info",
      "default": true
    },
    {
      "type": "select",
      "id": "surface_style",
      "label": "t:sections.stone_featured_product_showcase.settings.surface_style.label",
      "info": "t:sections.stone_featured_product_showcase.settings.surface_style.info",
      "default": "outline",
      "options": [
        {
          "value": "outline",
          "label": "t:sections.stone_featured_product_showcase.settings.surface_style.options.outline.label"
        },
        {
          "value": "soft",
          "label": "t:sections.stone_featured_product_showcase.settings.surface_style.options.soft.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_featured_product_showcase.settings.width_mode.label",
      "info": "t:sections.stone_featured_product_showcase.settings.width_mode.info",
      "default": "wide",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_featured_product_showcase.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_featured_product_showcase.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_featured_product_showcase.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_featured_product_showcase.settings.spacing_mode.label",
      "info": "t:sections.stone_featured_product_showcase.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_featured_product_showcase.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_featured_product_showcase.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_featured_product_showcase.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stone_featured_product_showcase.name"
    }
  ]
}
{% endschema %}
