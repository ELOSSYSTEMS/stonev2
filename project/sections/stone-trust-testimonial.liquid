{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_intro = section.settings.intro
  assign stone_intro_plain = stone_intro | strip_html | strip
  assign stone_surface_style = section.settings.surface_style | default: 'outline'
  assign stone_layout_mode = section.settings.layout_mode | default: 'grid'

  capture stone_section_content
    echo '<div class="stone-trust-testimonial stone-trust-testimonial--'
    echo stone_surface_style | escape
    echo ' stone-trust-testimonial--'
    echo stone_layout_mode | escape
    echo '">' 

    if stone_intro_plain != blank
      echo '<div class="stone-trust-testimonial__intro stone-richtext-flow rte">'
      echo stone_intro
      echo '</div>'
    endif

    if section.blocks.size > 0
      echo '<div class="stone-trust-testimonial__items">'
      for block in section.blocks
        assign stone_quote = block.settings.quote
        assign stone_quote_plain = stone_quote | strip_html | strip
        assign stone_author_name = block.settings.author_name | strip
        assign stone_author_context = block.settings.author_context | strip

        if stone_quote_plain != blank or stone_author_name != blank or stone_author_context != blank
          echo '<figure class="stone-trust-testimonial__item"'
          echo block.shopify_attributes
          echo '>'

          if stone_quote_plain != blank
            echo '<blockquote class="stone-trust-testimonial__quote stone-richtext-flow rte">'
            echo stone_quote
            echo '</blockquote>'
          else
            echo '<p class="stone-trust-testimonial__empty-item">'
            echo 'sections.stone_trust_testimonial.blocks.item.empty_quote' | t
            echo '</p>'
          endif

          echo '<figcaption class="stone-trust-testimonial__attribution">'
          if stone_author_name != blank
            echo '<p class="stone-trust-testimonial__name">'
            echo stone_author_name | escape
            echo '</p>'
          else
            echo '<p class="stone-trust-testimonial__name">'
            echo 'sections.stone_trust_testimonial.blocks.item.fallback_author' | t
            echo '</p>'
          endif

          if stone_author_context != blank
            echo '<p class="stone-trust-testimonial__context">'
            echo stone_author_context | escape
            echo '</p>'
          endif
          echo '</figcaption>'

          echo '</figure>'
        endif
      endfor
      echo '</div>'
    else
      echo '<p class="stone-trust-testimonial__empty">'
      echo 'sections.stone_trust_testimonial.empty' | t
      echo '</p>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell',
    section: section,
    heading: stone_heading,
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-trust-testimonial-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_trust_testimonial.name",
  "tag": "section",
  "class": "shopify-section--stone-trust-testimonial",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_trust_testimonial.settings.heading.label",
      "info": "t:sections.stone_trust_testimonial.settings.heading.info"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.stone_trust_testimonial.settings.intro.label",
      "info": "t:sections.stone_trust_testimonial.settings.intro.info"
    },
    {
      "type": "select",
      "id": "surface_style",
      "label": "t:sections.stone_trust_testimonial.settings.surface_style.label",
      "info": "t:sections.stone_trust_testimonial.settings.surface_style.info",
      "default": "outline",
      "options": [
        {
          "value": "outline",
          "label": "t:sections.stone_trust_testimonial.settings.surface_style.options.outline.label"
        },
        {
          "value": "soft",
          "label": "t:sections.stone_trust_testimonial.settings.surface_style.options.soft.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "t:sections.stone_trust_testimonial.settings.layout_mode.label",
      "info": "t:sections.stone_trust_testimonial.settings.layout_mode.info",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "t:sections.stone_trust_testimonial.settings.layout_mode.options.grid.label"
        },
        {
          "value": "stack",
          "label": "t:sections.stone_trust_testimonial.settings.layout_mode.options.stack.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_trust_testimonial.settings.width_mode.label",
      "info": "t:sections.stone_trust_testimonial.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_trust_testimonial.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_trust_testimonial.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_trust_testimonial.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_trust_testimonial.settings.spacing_mode.label",
      "info": "t:sections.stone_trust_testimonial.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_trust_testimonial.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_trust_testimonial.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_trust_testimonial.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "t:sections.stone_trust_testimonial.blocks.item.name",
      "settings": [
        {
          "type": "richtext",
          "id": "quote",
          "label": "t:sections.stone_trust_testimonial.blocks.item.settings.quote.label",
          "info": "t:sections.stone_trust_testimonial.blocks.item.settings.quote.info"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "t:sections.stone_trust_testimonial.blocks.item.settings.author_name.label",
          "info": "t:sections.stone_trust_testimonial.blocks.item.settings.author_name.info"
        },
        {
          "type": "text",
          "id": "author_context",
          "label": "t:sections.stone_trust_testimonial.blocks.item.settings.author_context.label",
          "info": "t:sections.stone_trust_testimonial.blocks.item.settings.author_context.info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stone_trust_testimonial.name",
      "blocks": [
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
