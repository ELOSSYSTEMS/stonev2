{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_intro = section.settings.intro
  assign stone_intro_plain = stone_intro | strip_html | strip
  assign stone_surface_style = section.settings.surface_style | default: 'outline'
  assign stone_layout_mode = section.settings.layout_mode | default: 'grid'

  capture stone_section_content
    echo '<div class="stone-trust-stat-strip stone-trust-stat-strip--'
    echo stone_surface_style | escape
    echo ' stone-trust-stat-strip--'
    echo stone_layout_mode | escape
    echo '">'

    if stone_intro_plain != blank
      echo '<div class="stone-trust-stat-strip__intro stone-richtext-flow rte">'
      echo stone_intro
      echo '</div>'
    endif

    if section.blocks.size > 0
      echo '<div class="stone-trust-stat-strip__items">'
      for block in section.blocks
        assign stone_value = block.settings.value | strip
        assign stone_label = block.settings.label | strip
        assign stone_note = block.settings.note | strip

        if stone_value != blank or stone_label != blank or stone_note != blank
          echo '<div class="stone-trust-stat-strip__item"'
          echo block.shopify_attributes
          echo '>'

          if stone_value != blank
            echo '<p class="stone-trust-stat-strip__value">'
            echo stone_value | escape
            echo '</p>'
          else
            echo '<p class="stone-trust-stat-strip__value">'
            echo 'sections.stone_trust_stat_strip.blocks.item.empty_value' | t
            echo '</p>'
          endif

          if stone_label != blank
            echo '<p class="stone-trust-stat-strip__label">'
            echo stone_label | escape
            echo '</p>'
          else
            echo '<p class="stone-trust-stat-strip__label">'
            echo 'sections.stone_trust_stat_strip.blocks.item.fallback_label' | t
            echo '</p>'
          endif

          if stone_note != blank
            echo '<p class="stone-trust-stat-strip__note">'
            echo stone_note | escape
            echo '</p>'
          endif

          echo '</div>'
        endif
      endfor
      echo '</div>'
    else
      echo '<p class="stone-trust-stat-strip__empty">'
      echo 'sections.stone_trust_stat_strip.empty' | t
      echo '</p>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell',
    section: section,
    heading: stone_heading,
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-trust-stat-strip-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_trust_stat_strip.name",
  "tag": "section",
  "class": "shopify-section--stone-trust-stat-strip",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_trust_stat_strip.settings.heading.label",
      "info": "t:sections.stone_trust_stat_strip.settings.heading.info"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.stone_trust_stat_strip.settings.intro.label",
      "info": "t:sections.stone_trust_stat_strip.settings.intro.info"
    },
    {
      "type": "select",
      "id": "surface_style",
      "label": "t:sections.stone_trust_stat_strip.settings.surface_style.label",
      "info": "t:sections.stone_trust_stat_strip.settings.surface_style.info",
      "default": "outline",
      "options": [
        {
          "value": "outline",
          "label": "t:sections.stone_trust_stat_strip.settings.surface_style.options.outline.label"
        },
        {
          "value": "soft",
          "label": "t:sections.stone_trust_stat_strip.settings.surface_style.options.soft.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "t:sections.stone_trust_stat_strip.settings.layout_mode.label",
      "info": "t:sections.stone_trust_stat_strip.settings.layout_mode.info",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "t:sections.stone_trust_stat_strip.settings.layout_mode.options.grid.label"
        },
        {
          "value": "stack",
          "label": "t:sections.stone_trust_stat_strip.settings.layout_mode.options.stack.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_trust_stat_strip.settings.width_mode.label",
      "info": "t:sections.stone_trust_stat_strip.settings.width_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_trust_stat_strip.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_trust_stat_strip.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_trust_stat_strip.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_trust_stat_strip.settings.spacing_mode.label",
      "info": "t:sections.stone_trust_stat_strip.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_trust_stat_strip.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_trust_stat_strip.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_trust_stat_strip.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "t:sections.stone_trust_stat_strip.blocks.item.name",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "t:sections.stone_trust_stat_strip.blocks.item.settings.value.label",
          "info": "t:sections.stone_trust_stat_strip.blocks.item.settings.value.info"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.stone_trust_stat_strip.blocks.item.settings.label.label",
          "info": "t:sections.stone_trust_stat_strip.blocks.item.settings.label.info"
        },
        {
          "type": "text",
          "id": "note",
          "label": "t:sections.stone_trust_stat_strip.blocks.item.settings.note.label",
          "info": "t:sections.stone_trust_stat_strip.blocks.item.settings.note.info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stone_trust_stat_strip.name",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
