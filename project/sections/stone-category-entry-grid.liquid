{%- liquid
  assign stone_heading = section.settings.heading | strip
  assign stone_intro = section.settings.intro
  assign stone_intro_plain = stone_intro | strip_html | strip
  assign stone_surface_style = section.settings.surface_style | default: 'outline'
  assign stone_collection_primary = section.settings.collection_primary
  assign stone_collection_secondary = section.settings.collection_secondary
  assign stone_collection_tertiary = section.settings.collection_tertiary
  assign stone_selected_count = 0

  if stone_collection_primary != blank
    assign stone_selected_count = stone_selected_count | plus: 1
  endif
  if stone_collection_secondary != blank
    assign stone_selected_count = stone_selected_count | plus: 1
  endif
  if stone_collection_tertiary != blank
    assign stone_selected_count = stone_selected_count | plus: 1
  endif

  capture stone_section_content
    echo '<div class="stone-category-entry-grid stone-category-entry-grid--'
    echo stone_surface_style | escape
    echo '">'

    if stone_intro_plain != blank
      echo '<div class="stone-category-entry-grid__intro stone-richtext-flow rte">'
      echo stone_intro
      echo '</div>'
    endif

    if stone_selected_count > 0
      echo '<div class="stone-category-entry-grid__summary">'
      echo '<p class="stone-category-entry-grid__eyebrow">'
      echo 'sections.stone_category_entry_grid.collection_label' | t
      echo '</p>'
      echo '<p class="stone-category-entry-grid__meta">'
      echo 'sections.stone_category_entry_grid.selected_count' | t: count: stone_selected_count
      echo '</p>'
      echo '</div>'

      echo '<div class="stone-category-entry-grid__items">'
      if stone_collection_primary != blank
        render 'stone-collection-card', collection: stone_collection_primary, surface_style: stone_surface_style
      endif
      if stone_collection_secondary != blank
        render 'stone-collection-card', collection: stone_collection_secondary, surface_style: stone_surface_style
      endif
      if stone_collection_tertiary != blank
        render 'stone-collection-card', collection: stone_collection_tertiary, surface_style: stone_surface_style
      endif
      echo '</div>'
    else
      echo '<p class="stone-category-entry-grid__empty">'
      echo 'sections.stone_category_entry_grid.empty_state' | t
      echo '</p>'
    endif

    echo '</div>'
  endcapture

  render 'stone-section-shell',
    section: section,
    heading: stone_heading,
    content: stone_section_content,
    width: section.settings.width_mode,
    spacing: section.settings.spacing_mode,
    shell_class: 'stone-category-entry-grid-shell'
-%}

{% schema %}
{
  "name": "t:sections.stone_category_entry_grid.name",
  "tag": "section",
  "class": "shopify-section--stone-category-entry-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.stone_category_entry_grid.settings.heading.label",
      "info": "t:sections.stone_category_entry_grid.settings.heading.info"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "t:sections.stone_category_entry_grid.settings.intro.label",
      "info": "t:sections.stone_category_entry_grid.settings.intro.info"
    },
    {
      "type": "collection",
      "id": "collection_primary",
      "label": "t:sections.stone_category_entry_grid.settings.collection_primary.label",
      "info": "t:sections.stone_category_entry_grid.settings.collection_primary.info"
    },
    {
      "type": "collection",
      "id": "collection_secondary",
      "label": "t:sections.stone_category_entry_grid.settings.collection_secondary.label",
      "info": "t:sections.stone_category_entry_grid.settings.collection_secondary.info"
    },
    {
      "type": "collection",
      "id": "collection_tertiary",
      "label": "t:sections.stone_category_entry_grid.settings.collection_tertiary.label",
      "info": "t:sections.stone_category_entry_grid.settings.collection_tertiary.info"
    },
    {
      "type": "select",
      "id": "surface_style",
      "label": "t:sections.stone_category_entry_grid.settings.surface_style.label",
      "info": "t:sections.stone_category_entry_grid.settings.surface_style.info",
      "default": "outline",
      "options": [
        {
          "value": "outline",
          "label": "t:sections.stone_category_entry_grid.settings.surface_style.options.outline.label"
        },
        {
          "value": "soft",
          "label": "t:sections.stone_category_entry_grid.settings.surface_style.options.soft.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "width_mode",
      "label": "t:sections.stone_category_entry_grid.settings.width_mode.label",
      "info": "t:sections.stone_category_entry_grid.settings.width_mode.info",
      "default": "wide",
      "options": [
        {
          "value": "narrow",
          "label": "t:sections.stone_category_entry_grid.settings.width_mode.options.narrow.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_category_entry_grid.settings.width_mode.options.standard.label"
        },
        {
          "value": "wide",
          "label": "t:sections.stone_category_entry_grid.settings.width_mode.options.wide.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_mode",
      "label": "t:sections.stone_category_entry_grid.settings.spacing_mode.label",
      "info": "t:sections.stone_category_entry_grid.settings.spacing_mode.info",
      "default": "standard",
      "options": [
        {
          "value": "compact",
          "label": "t:sections.stone_category_entry_grid.settings.spacing_mode.options.compact.label"
        },
        {
          "value": "standard",
          "label": "t:sections.stone_category_entry_grid.settings.spacing_mode.options.standard.label"
        },
        {
          "value": "relaxed",
          "label": "t:sections.stone_category_entry_grid.settings.spacing_mode.options.relaxed.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stone_category_entry_grid.name"
    }
  ]
}
{% endschema %}
